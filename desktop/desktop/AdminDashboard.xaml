<Window x:Class="desktop.AdminDashboard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:desktop"
        mc:Ignorable="d"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="FanVerse Admin Panel"
        WindowStartupLocation="CenterScreen"
        Width="1400" Height="800"
        Background="#0B0A1A"
        WindowStyle="None"
        AllowsTransparency="True">

    <Window.Resources>

        <LinearGradientBrush x:Key="SidebarGradient" 
                             StartPoint="0,0" 
                             EndPoint="0,1">
            <GradientStop Color="#1A142F" 
                          Offset="0"/>
            <GradientStop Color="#0F0C1A" 
                          Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="PrimaryGradient" 
                             StartPoint="0,0" 
                             EndPoint="1,1">
            <GradientStop Color="#8A2BE2" 
                          Offset="0"/>
            <GradientStop Color="#FF3C82" 
                          Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Height" 
                    Value="50"/>
            <Setter Property="HorizontalAlignment" 
                    Value="Stretch"/>
            <Setter Property="Background" 
                    Value="Transparent"/>
            <Setter Property="Foreground" 
                    Value="#AAA"/>
            <Setter Property="BorderThickness" 
                    Value="0"/>
            <Setter Property="FontSize" 
                    Value="14"/>
            <Setter Property="FontWeight" 
                    Value="Medium"/>
            <Setter Property="Cursor" 
                    Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="Border" 
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="8"
                                    Margin="12,2,12,2">
                                <StackPanel Orientation="Horizontal" 
                                            Margin="16,0" 
                                            VerticalAlignment="Center">
                                    <ContentPresenter x:Name="Icon"
                                                      Content="{TemplateBinding Content}"
                                                      Width="20"
                                                      Height="20"
                                                      Margin="0,0,12,0"/>
                                    <TextBlock x:Name="Text"
                                               Text="{TemplateBinding Tag}"
                                               VerticalAlignment="Center"
                                               FontSize="14"
                                               Foreground="{TemplateBinding Foreground}"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" 
                                     Value="True">
                                <Setter TargetName="Border" 
                                        Property="Background" 
                                        Value="#2A2438"/>
                                <Setter TargetName="Text" 
                                        Property="Foreground" 
                                        Value="#FFFFFF"/>
                                <Setter TargetName="Icon" 
                                        Property="Opacity" 
                                        Value="1"/>
                            </Trigger>
                            <Trigger Property="IsPressed" 
                                     Value="True">
                                <Setter TargetName="Border" 
                                        Property="Background" 
                                        Value="#3A3450"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActiveNavButtonStyle" 
               TargetType="Button" 
               BasedOn="{StaticResource NavButtonStyle}">
            <Setter Property="Background" 
                    Value="#2A2438"/>
            <Setter Property="Foreground" 
                    Value="#FFFFFF"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border Background="#2A2438"
                                    CornerRadius="8"
                                    Margin="12,2,12,2">
                                <Border.BorderBrush>
                                    <LinearGradientBrush StartPoint="0,0"
                                                         EndPoint="1,0">
                                        <GradientStop Color="#8A2BE2" 
                                                      Offset="0"/>
                                        <GradientStop Color="#FF3C82"
                                                      Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.BorderBrush>
                                <Border BorderThickness="2,0,0,0" 
                                        CornerRadius="8">
                                    <StackPanel Orientation="Horizontal" 
                                                Margin="16,0" 
                                                VerticalAlignment="Center">
                                        <ContentPresenter x:Name="Icon"
                                                          Content="{TemplateBinding Content}"
                                                          Width="20"
                                                          Height="20"
                                                          Margin="0,0,12,0"/>
                                        <TextBlock x:Name="Text"
                                                   Text="{TemplateBinding Tag}"
                                                   VerticalAlignment="Center"
                                                   FontSize="14"
                                                   Foreground="#FFFFFF"/>
                                    </StackPanel>
                                </Border>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseButtonStyle" 
               TargetType="Button">
            <Setter Property="Width" 
                    Value="35"/>
            <Setter Property="Height" 
                    Value="35"/>
            <Setter Property="Background" 
                    Value="Transparent"/>
            <Setter Property="Foreground"
                    Value="#888"/>
            <Setter Property="BorderThickness" 
                    Value="0"/>
            <Setter Property="FontSize" 
                    Value="18"/>
            <Setter Property="Cursor" 
                    Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse x:Name="BgCircle" 
                                     Fill="Transparent"
                                     Width="35" Height="35"/>
                            <TextBlock x:Name="CloseText" 
                                       Text="✕" 
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" 
                                       FontSize="18" 
                                       Foreground="{TemplateBinding Foreground}"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" 
                                     Value="True">
                                <Setter TargetName="BgCircle" 
                                        Property="Fill" 
                                        Value="#FF5252"/>
                                <Setter TargetName="CloseText" 
                                        Property="Foreground"
                                        Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" 
                                     Value="True">
                                <Setter TargetName="BgCircle" 
                                        Property="Fill"
                                        Value="#D32F2F"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MinimizeButtonStyle" 
               TargetType="Button">
            <Setter Property="Width" 
                    Value="35"/>
            <Setter Property="Height" 
                    Value="35"/>
            <Setter Property="Background" 
                    Value="Transparent"/>
            <Setter Property="Foreground" 
                    Value="#888"/>
            <Setter Property="BorderThickness"
                    Value="0"/>
            <Setter Property="FontSize" 
                    Value="18"/>
            <Setter Property="Cursor" 
                    Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse x:Name="BgCircle" 
                                     Fill="Transparent" 
                                     Width="35" 
                                     Height="35"/>
                            <TextBlock x:Name="MinimizeText" 
                                       Text="─" 
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" 
                                       FontSize="20" 
                                       Foreground="{TemplateBinding Foreground}"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" 
                                     Value="True">
                                <Setter TargetName="BgCircle"
                                        Property="Fill" 
                                        Value="#2A2438"/>
                                <Setter TargetName="MinimizeText" 
                                        Property="Foreground" 
                                        Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Border" 
               x:Key="AvatarOverlayStyle">
            <Setter Property="Background" 
                    Value="#80000000"/>
            <Setter Property="CornerRadius" 
                    Value="40"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" 
                         Value="True">
                    <Setter Property="Visibility" 
                            Value="Visible"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>

    <Grid>

        <Border CornerRadius="16" 
                Background="#0B0A1A" 
                Margin="5">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" 
                        Background="{StaticResource SidebarGradient}" 
                        CornerRadius="12,0,0,12">

                    <Border BorderBrush="#2A2438" 
                            BorderThickness="0,0,1,0">

                        <StackPanel>

                            <Border Height="70" 
                                    Margin="0,20,0,10">
                                <StackPanel HorizontalAlignment="Left" 
                                            VerticalAlignment="Center"
                                            Margin="20,0,0,0">
                                    <TextBlock FontSize="24" 
                                               FontWeight="Bold" 
                                               FontFamily="Segoe UI" 
                                               TextAlignment="Center">
                                        <Run Text="FAN" 
                                             Foreground="#8A2BE2"/>
                                        <Run Text="VERSE" 
                                             Foreground="#FF3C82"/>
                                    </TextBlock>
                                    <TextBlock Text="Между строк рождаются миры" 
                                               FontSize="10"
                                               Foreground="#666" 
                                               HorizontalAlignment="Left"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Background="#1A142F" 
                                    Margin="16,10,16,20" 
                                    CornerRadius="12" 
                                    Padding="12">
                                <StackPanel>
                                    <Border x:Name="AvatarBorder" 
                                            Width="80" 
                                            Height="80" 
                                            HorizontalAlignment="Center" 
                                            Margin="0,10"
                                            Cursor="Hand"
                                            IsHitTestVisible="True"
                                            MouseLeftButtonUp="AvatarBorder_MouseLeftButtonUp"
                                            CornerRadius="40">

                                        <Border.ToolTip>
                                            <ToolTip Content="Нажмите, чтобы изменить аватар"/>
                                        </Border.ToolTip>

                                        <Grid Width="80" 
                                              Height="80">
                                            <Ellipse x:Name="AvatarEllipse" 
                                                     Width="80" 
                                                     Height="80">
                                                <Ellipse.Fill>
                                                    <ImageBrush x:Name="AvatarImageBrush" 
                                                                ImageSource="/Assets/static.jpg" 
                                                                Stretch="UniformToFill"/>
                                                </Ellipse.Fill>
                                                <Ellipse.Effect>
                                                    <DropShadowEffect Color="#8A2BE2" 
                                                                      BlurRadius="15" 
                                                                      Opacity="0.5"/>
                                                </Ellipse.Effect>
                                            </Ellipse>

                                            <Border x:Name="CameraOverlay" 
                                                    Background="#80000000" 
                                                    CornerRadius="40" 
                                                    Visibility="Collapsed">
                                                <TextBlock Text="📷" 
                                                           FontSize="24" 
                                                           Foreground="White" 
                                                           HorizontalAlignment="Center" 
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                        </Grid>

                                        <Border.InputBindings>
                                            <MouseBinding MouseAction="LeftClick" 
                                                          Command="{Binding ChangeAvatarCommand}" 
                                                          CommandParameter="{Binding ElementName=AvatarBorder}"/>
                                        </Border.InputBindings>
                                    </Border>

                                    <TextBlock x:Name="AdminNameText" 
                                               Text="Загрузка..." 
                                               FontSize="14" 
                                               FontWeight="Bold" 
                                               Foreground="#FFFFFF" 
                                               HorizontalAlignment="Center"
                                               Margin="0,10,0,2"/>

                                    <TextBlock Text="Администратор" 
                                               FontSize="11" 
                                               Foreground="#8A2BE2" 
                                               HorizontalAlignment="Center"
                                               Opacity="0.8"/>
                                </StackPanel>
                            </Border>

                            <StackPanel Margin="0,10,0,0">
                                <TextBlock Text="ГЛАВНОЕ" 
                                           FontSize="11" 
                                           Foreground="#666" 
                                           Margin="24,10,0,5"/>

                                <Button x:Name="NavAdminButton" 
                                        Style="{StaticResource NavButtonStyle}"
                                        Tag="Администрация"
                                        Click="NavButton_Click">
                                    <Button.Content>
                                        <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 3c1.66 0 3 1.34 3 3s-1.34 3-3 3-3-1.34-3-3 1.34-3 3-3zm0 14.2c-2.5 0-4.71-1.28-6-3.22.03-1.99 4-3.08 6-3.08 1.99 0 5.97 1.09 6 3.08-1.29 1.94-3.5 3.22-6 3.22z"
                                              Stretch="Uniform"
                                              Fill="#AAA" 
                                              Width="18" 
                                              Height="18"/>
                                    </Button.Content>
                                </Button>

                                <Button x:Name="NavContentButton" 
                                        Style="{StaticResource NavButtonStyle}"
                                        Tag="Контент"
                                        Click="NavButton_Click">
                                    <Button.Content>
                                        <Path Data="M4 6h16v2H4V6zm0 4h16v2H4v-2zm0 4h10v2H4v-2zm13 0h3v2h-3v-2zm-3-4h6v2h-6v-2zM4 18h16v2H4v-2z"
                                              Stretch="Uniform"
                                              Fill="#AAA" 
                                              Width="18" 
                                              Height="18"/>
                                    </Button.Content>
                                </Button>

                                <Button x:Name="NavStatsButton" 
                                        Style="{StaticResource NavButtonStyle}"
                                        Tag="Статистика"
                                        Click="NavButton_Click">
                                    <Button.Content>
                                        <Path Data="M3 13h8V3H3v10zm0 8h8v-6H3v6zm10 0h8V11h-8v10zm0-18v6h8V3h-8z"
                                              Fill="#AAA" 
                                              Stretch="Uniform"
                                              Width="18" 
                                              Height="18"/>
                                    </Button.Content>
                                </Button>

                                <Button x:Name="NavBooksButton" 
                                        Style="{StaticResource NavButtonStyle}"
                                        Tag="Книги"
                                        Click="NavButton_Click">
                                    <Button.Content>
                                        <Path Data="M4 6H2v14c0 1.1.9 2 2 2h14v-2H4V6zm16-4H8c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm-3 9H9V9h8v2zm-4 4H9v-2h4v2zm4-8H9V5h8v2z"
                                              Fill="#AAA" 
                                              Stretch="Uniform"
                                              Width="18" 
                                              Height="18"/>
                                    </Button.Content>
                                </Button>

                                <Button x:Name="NavUsersButton" 
                                        Style="{StaticResource NavButtonStyle}"
                                        Tag="Пользователи"
                                        Click="NavButton_Click">
                                    <Button.Content>
                                        <Path Data="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-1 .05 1.16.84 2 1.87 2 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"
                                              Stretch="Uniform"
                                              Fill="#AAA" 
                                              Width="18" 
                                              Height="18"/>
                                    </Button.Content>
                                </Button>
                            </StackPanel>

                            <StackPanel VerticalAlignment="Bottom" Margin="0,40,0,20">
                                <TextBlock Text="СИСТЕМА" 
                                           FontSize="11" 
                                           Foreground="#666" 
                                           Margin="24,10,0,5"/>

                                <Button x:Name="NavLogoutButton" 
                                        Style="{StaticResource NavButtonStyle}"
                                        Tag="Выйти"
                                        Click="LogoutButton_Click">
                                    <Button.Content>
                                        <Path Data="M17 7l-1.41 1.41L18.17 11H8v2h10.17l-2.58 2.58L17 17l5-5zM4 5h8V3H4c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h8v-2H4V5z"
                                              Stretch="Uniform"
                                              Fill="#AAA" 
                                              Width="18" 
                                              Height="18"/>
                                    </Button.Content>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Border>

                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="50"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" 
                            Background="#1A142F"
                            CornerRadius="0,12,0,0"
                            MouseLeftButtonDown="TopBar_MouseLeftButtonDown">
                        <Grid Margin="20,0">
                            <StackPanel Orientation="Horizontal" 
                                        HorizontalAlignment="Left" 
                                        VerticalAlignment="Center">
                                <TextBlock x:Name="PageTitleText" 
                                           Text="Администрация" 
                                           FontSize="18" 
                                           FontWeight="SemiBold" 
                                           Foreground="#FFFFFF"/>
                                <Border Width="4"
                                        Height="4" 
                                        CornerRadius="2" 
                                        Background="#8A2BE2" 
                                        VerticalAlignment="Center" 
                                        Margin="12,0,0,0"/>
                                <TextBlock x:Name="PageSubtitleText" 
                                           Text="Управление администраторами" 
                                           FontSize="12" 
                                           Foreground="#888" 
                                           Margin="12,0,0,0"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" 
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center">
                                <Button Style="{StaticResource MinimizeButtonStyle}" 
                                        Click="MinimizeButton_Click"/>
                                <Button Style="{StaticResource CloseButtonStyle}"
                                        Click="CloseButton_Click"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1" 
                            Background="#0F0C1A" 
                            CornerRadius="0,0,12,0">
                        <Frame x:Name="ContentFrame" 
                               NavigationUIVisibility="Hidden"
                               Background="Transparent"/>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>