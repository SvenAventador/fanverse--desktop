<Page x:Class="desktop.Pages.Dashboard.StatisticsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d" 
      Background="Transparent"
      Title="StatisticsPage">

    <Page.Resources>
        <LinearGradientBrush x:Key="PrimaryGradient" 
                             StartPoint="0,0" 
                             EndPoint="1,1">
            <GradientStop Color="#8A2BE2" 
                          Offset="0"/>
            <GradientStop Color="#FF3C82"
                          Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="CardGradient" 
                             StartPoint="0,0" 
                             EndPoint="1,1">
            <GradientStop Color="#1E1B2E" 
                          Offset="0"/>
            <GradientStop Color="#151225" 
                          Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="SuccessGradient" 
                             StartPoint="0,0"
                             EndPoint="1,1">
            <GradientStop Color="#4CAF50" 
                          Offset="0"/>
            <GradientStop Color="#45A049" 
                          Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="WarningGradient"
                             StartPoint="0,0" 
                             EndPoint="1,1">
            <GradientStop Color="#FF9800" 
                          Offset="0"/>
            <GradientStop Color="#F57C00" 
                          Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="DangerGradient" 
                             StartPoint="0,0"
                             EndPoint="1,1">
            <GradientStop Color="#FF5252" 
                          Offset="0"/>
            <GradientStop Color="#E53935" 
                          Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="InfoGradient" 
                             StartPoint="0,0" 
                             EndPoint="1,1">
            <GradientStop Color="#2196F3" 
                          Offset="0"/>
            <GradientStop Color="#1976D2" 
                          Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="StatCardStyle"
               TargetType="Border">
            <Setter Property="Background" 
                    Value="{StaticResource CardGradient}"/>
            <Setter Property="CornerRadius" 
                    Value="16"/>
            <Setter Property="Padding" 
                    Value="20"/>
            <Setter Property="Margin" 
                    Value="10"/>
            <Setter Property="MinWidth" 
                    Value="200"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#8A2BE2" 
                                      Opacity="0.15" 
                                      BlurRadius="15" 
                                      ShadowDepth="0"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StatValueStyle" 
               TargetType="TextBlock">
            <Setter Property="FontSize" 
                    Value="32"/>
            <Setter Property="FontWeight" 
                    Value="Bold"/>
            <Setter Property="Foreground" 
                    Value="#FFFFFF"/>
            <Setter Property="FontFamily" 
                    Value="Segoe UI"/>
        </Style>

        <Style x:Key="StatTitleStyle" 
               TargetType="TextBlock">
            <Setter Property="FontSize" 
                    Value="13"/>
            <Setter Property="Foreground" 
                    Value="#888"/>
            <Setter Property="Margin" 
                    Value="0,5,0,0"/>
        </Style>

        <Style x:Key="StatIconStyle" 
               TargetType="Border">
            <Setter Property="Width" 
                    Value="50"/>
            <Setter Property="Height"
                    Value="50"/>
            <Setter Property="CornerRadius" 
                    Value="12"/>
            <Setter Property="HorizontalAlignment"
                    Value="Right"/>
            <Setter Property="VerticalAlignment" 
                    Value="Top"/>
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Hidden" 
              HorizontalScrollBarVisibility="Hidden" >
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" 
                       Text="Панель аналитики"
                       FontSize="24" 
                       FontWeight="Bold"
                       Foreground="#FFFFFF"
                       Margin="0,0,0,20"/>

            <WrapPanel Grid.Row="1" 
                       Margin="0,0,0,20">

                <Border Style="{StaticResource StatCardStyle}" 
                        Width="220">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" 
                                Style="{StaticResource StatIconStyle}" 
                                Background="#8A2BE2" 
                                Opacity="0.2" 
                                HorizontalAlignment="Right">
                            <TextBlock Text="👥" 
                                       FontSize="24" 
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Grid.Row="1" 
                                   x:Name="TotalUsersValue" 
                                   Text="0" 
                                   Style="{StaticResource StatValueStyle}" 
                                   Margin="0,10,0,0"/>
                        <TextBlock Grid.Row="2" 
                                   Text="Всего пользователей" 
                                   Style="{StaticResource StatTitleStyle}" 
                                   Margin="0,5,0,0"/>
                    </Grid>
                </Border>

                <Border Style="{StaticResource StatCardStyle}" 
                        Width="220">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" 
                                Style="{StaticResource StatIconStyle}" 
                                Background="#4CAF50" 
                                Opacity="0.2" 
                                HorizontalAlignment="Right">
                            <TextBlock Text="🟢" 
                                       FontSize="24" 
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Grid.Row="1" 
                                   x:Name="ActiveUsersValue" 
                                   Text="0" 
                                   Style="{StaticResource StatValueStyle}" 
                                   Margin="0,10,0,0"/>
                        <TextBlock Grid.Row="2"
                                   Text="Активные пользователи"
                                   Style="{StaticResource StatTitleStyle}" 
                                   Margin="0,5,0,0"/>
                    </Grid>
                </Border>

                <Border Style="{StaticResource StatCardStyle}"
                        Width="220">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" 
                                Style="{StaticResource StatIconStyle}" 
                                Background="#FF5252" 
                                Opacity="0.2"
                                HorizontalAlignment="Right">
                            <TextBlock Text="🚫" 
                                       FontSize="24" 
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Grid.Row="1" 
                                   x:Name="BannedUsersValue" 
                                   Text="0" 
                                   Style="{StaticResource StatValueStyle}" 
                                   Foreground="#FF5252"
                                   Margin="0,10,0,0"/>
                        <TextBlock Grid.Row="2" 
                                   Text="Забаненные"
                                   Style="{StaticResource StatTitleStyle}"
                                   Margin="0,5,0,0"/>
                    </Grid>
                </Border>

                <Border Style="{StaticResource StatCardStyle}" Width="220">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" 
                                Style="{StaticResource StatIconStyle}" 
                                Background="#FF9800" 
                                Opacity="0.2" 
                                HorizontalAlignment="Right">
                            <TextBlock Text="🛡️" 
                                       FontSize="24" 
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Grid.Row="1" 
                                   x:Name="ModeratorsValue" 
                                   Text="0" 
                                   Style="{StaticResource StatValueStyle}" 
                                   Margin="0,10,0,0"/>
                        <TextBlock Grid.Row="2" 
                                   Text="Модераторы"
                                   Style="{StaticResource StatTitleStyle}" 
                                   Margin="0,5,0,0"/>
                    </Grid>
                </Border>
            </WrapPanel>

            <WrapPanel Grid.Row="2" Margin="0,0,0,20">
                <Border Style="{StaticResource StatCardStyle}" 
                        Width="220">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" 
                                Style="{StaticResource StatIconStyle}" 
                                Background="#2196F3" 
                                Opacity="0.2" 
                                HorizontalAlignment="Right">
                            <TextBlock Text="📚" 
                                       FontSize="24" 
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Grid.Row="1" 
                                   x:Name="TotalBooksValue"
                                   Text="0" 
                                   Style="{StaticResource StatValueStyle}" 
                                   Margin="0,10,0,0"/>
                        <TextBlock Grid.Row="2" 
                                   Text="Всего книг" 
                                   Style="{StaticResource StatTitleStyle}" 
                                   Margin="0,5,0,0"/>
                        <StackPanel Grid.Row="3" 
                                    Orientation="Horizontal"
                                    Margin="0,10,0,0">
                            <TextBlock x:Name="PublishedBooksValue" 
                                       Text="0" 
                                       FontSize="12" 
                                       Foreground="#4CAF50"/>
                            <TextBlock Text=" опубликовано"
                                       FontSize="12"
                                       Foreground="#888"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Style="{StaticResource StatCardStyle}" 
                        Width="220">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" 
                                Style="{StaticResource StatIconStyle}"
                                Background="#9C27B0" 
                                Opacity="0.2" 
                                HorizontalAlignment="Right">
                            <TextBlock Text="📖" 
                                       FontSize="24" 
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Grid.Row="1" 
                                   x:Name="TotalChaptersValue"
                                   Text="0" 
                                   Style="{StaticResource StatValueStyle}"
                                   Margin="0,10,0,0"/>
                        <TextBlock Grid.Row="2" 
                                   Text="Всего глав" 
                                   Style="{StaticResource StatTitleStyle}"
                                   Margin="0,5,0,0"/>
                        <TextBlock Grid.Row="3"
                                   x:Name="AvgChaptersValue" 
                                   Text="0 глав на книгу" 
                                   FontSize="11" 
                                   Foreground="#888" 
                                   Margin="0,10,0,0"/>
                    </Grid>
                </Border>

                <Border Style="{StaticResource StatCardStyle}" 
                        Width="220">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" 
                                Style="{StaticResource StatIconStyle}" 
                                Background="#E91E63" 
                                Opacity="0.2" 
                                HorizontalAlignment="Right">
                            <TextBlock Text="🏷️" 
                                       FontSize="24" 
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Grid.Row="1" 
                                   x:Name="TotalGenresValue"
                                   Text="0" 
                                   Style="{StaticResource StatValueStyle}" 
                                   Margin="0,10,0,0"/>
                        <TextBlock Grid.Row="2" 
                                   Text="Жанров" 
                                   Style="{StaticResource StatTitleStyle}" 
                                   Margin="0,5,0,0"/>
                    </Grid>
                </Border>

                <Border Style="{StaticResource StatCardStyle}"
                        Width="220">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" 
                                Style="{StaticResource StatIconStyle}"
                                Background="#00BCD4" 
                                Opacity="0.2" 
                                HorizontalAlignment="Right">
                            <TextBlock Text="#️⃣" 
                                       FontSize="24" 
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Grid.Row="1" 
                                   x:Name="TotalTagsValue" 
                                   Text="0" 
                                   Style="{StaticResource StatValueStyle}" 
                                   Margin="0,10,0,0"/>
                        <TextBlock Grid.Row="2" 
                                   Text="Тегов"
                                   Style="{StaticResource StatTitleStyle}"
                                   Margin="0,5,0,0"/>
                    </Grid>
                </Border>
            </WrapPanel>

            <WrapPanel Grid.Row="3" 
                       Margin="0,0,0,20">
                <Border Style="{StaticResource StatCardStyle}"
                        Width="280">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0"
                                Style="{StaticResource StatIconStyle}" 
                                Background="#FF9800" 
                                Opacity="0.2" 
                                HorizontalAlignment="Right">
                            <TextBlock Text="⏳" 
                                       FontSize="24" 
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Grid.Row="1" 
                                   x:Name="PendingBooksValue" 
                                   Text="0" 
                                   Style="{StaticResource StatValueStyle}" 
                                   Foreground="#FF9800" 
                                   Margin="0,10,0,0"/>
                        <TextBlock Grid.Row="2" 
                                   Text="Книг на рассмотрении" 
                                   Style="{StaticResource StatTitleStyle}"
                                   Margin="0,5,0,0"/>
                    </Grid>
                </Border>

                <Border Style="{StaticResource StatCardStyle}" 
                        Width="280">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" 
                                Style="{StaticResource StatIconStyle}" 
                                Background="#FF9800" 
                                Opacity="0.2" 
                                HorizontalAlignment="Right">
                            <TextBlock Text="⏳" 
                                       FontSize="24" 
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Grid.Row="1"
                                   x:Name="PendingChaptersValue"
                                   Text="0" Style="{StaticResource StatValueStyle}" 
                                   Foreground="#FF9800" Margin="0,10,0,0"/>
                        <TextBlock Grid.Row="2" 
                                   Text="Глав на рассмотрении"
                                   Style="{StaticResource StatTitleStyle}" 
                                   Margin="0,5,0,0"/>
                    </Grid>
                </Border>

                <Border Style="{StaticResource StatCardStyle}" 
                        Width="280">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" 
                                Style="{StaticResource StatIconStyle}" 
                                Background="#4CAF50" 
                                Opacity="0.2" 
                                HorizontalAlignment="Right">
                            <TextBlock Text="✅" 
                                       FontSize="24" 
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Grid.Row="1" 
                                   x:Name="ModerationSuccessValue" 
                                   Text="0%" 
                                   Style="{StaticResource StatValueStyle}" 
                                   Foreground="#4CAF50" 
                                   Margin="0,10,0,0"/>
                        <TextBlock Grid.Row="2" 
                                   Text="Успех модерации" 
                                   Style="{StaticResource StatTitleStyle}" 
                                   Margin="0,5,0,0"/>
                    </Grid>
                </Border>
            </WrapPanel>

            <Grid Grid.Row="4" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource StatCardStyle}" Margin="10,0,5,0">
                    <StackPanel>
                        <TextBlock Text="🏆 Топ авторы" 
                                   FontSize="16" 
                                   FontWeight="Bold" 
                                   Foreground="#FFFFFF" 
                                   Margin="0,0,0,15"/>
                        <ItemsControl x:Name="TopAuthorsList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#2A2438" 
                                            BorderThickness="0,0,0,1" 
                                            Padding="0,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" 
                                                       Text="{Binding Rank}" 
                                                       FontSize="14" 
                                                       FontWeight="Bold" 
                                                       Foreground="#8A2BE2"
                                                       Width="30"/>
                                            <TextBlock Grid.Column="1" 
                                                       Text="{Binding Nickname}" 
                                                       FontSize="14" 
                                                       Foreground="#FFFFFF"/>
                                            <TextBlock Grid.Column="2" 
                                                       Text="{Binding BookCount}" 
                                                       FontSize="14" 
                                                       Foreground="#888"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" 
                        Style="{StaticResource StatCardStyle}" 
                        Margin="5,0,10,0">
                    <StackPanel>
                        <TextBlock Text="🔥 Топ книги" 
                                   FontSize="16" 
                                   FontWeight="Bold" 
                                   Foreground="#FFFFFF" 
                                   Margin="0,0,0,15"/>
                        <ItemsControl x:Name="TopBooksList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#2A2438" 
                                            BorderThickness="0,0,0,1" 
                                            Padding="0,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" 
                                                       Text="{Binding Rank}" 
                                                       FontSize="14" 
                                                       FontWeight="Bold" 
                                                       Foreground="#FF3C82" 
                                                       Width="30"/>
                                            <TextBlock Grid.Column="1" 
                                                       Text="{Binding Title}" 
                                                       FontSize="14" 
                                                       Foreground="#FFFFFF"/>
                                            <TextBlock Grid.Column="2" 
                                                       Text="{Binding Views}" 
                                                       FontSize="14" 
                                                       Foreground="#888"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>

            <StackPanel x:Name="LoadingPanel" 
                        Grid.RowSpan="5"
                        HorizontalAlignment="Center" 
                        VerticalAlignment="Center"
                        Visibility="Collapsed">
                <Border Width="50" 
                        Height="50" 
                        CornerRadius="25" 
                        BorderBrush="#8A2BE2" 
                        BorderThickness="3">
                    <Border.RenderTransform>
                        <RotateTransform CenterX="25" 
                                         CenterY="25"/>
                    </Border.RenderTransform>
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <Trigger Property="Visibility" 
                                         Value="Visible">
                                    <Trigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever">
                                                <DoubleAnimation From="0" 
                                                                 To="360" 
                                                                 Duration="0:0:1" 
                                                                 Storyboard.TargetProperty="RenderTransform.Angle"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.EnterActions>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                </Border>
                <TextBlock Text="Загрузка статистики..." 
                           Foreground="#888" 
                           Margin="0,10,0,0"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>