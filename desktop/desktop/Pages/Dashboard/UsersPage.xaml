<Page x:Class="desktop.Pages.Dashboard.UsersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d" 
      Background="Transparent"
      xmlns:converters="clr-namespace:desktop.Converters"
      Title="UsersPage">

    <Page.Resources>
        <LinearGradientBrush x:Key="PrimaryGradient" 
                             StartPoint="0,0" 
                             EndPoint="1,1">
            <GradientStop Color="#8A2BE2" 
                          Offset="0"/>
            <GradientStop Color="#FF3C82" 
                          Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="CardGradient" 
                             StartPoint="0,0" 
                             EndPoint="1,1">
            <GradientStop Color="#1E1B2E" 
                          Offset="0"/>
            <GradientStop Color="#151225" 
                          Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="SuccessGradient" 
                             StartPoint="0,0" 
                             EndPoint="1,1">
            <GradientStop Color="#4CAF50" 
                          Offset="0"/>
            <GradientStop Color="#45A049"
                          Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="DangerGradient" 
                             StartPoint="0,0" 
                             EndPoint="1,1">
            <GradientStop Color="#FF5252" 
                          Offset="0"/>
            <GradientStop Color="#E53935" 
                          Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="UserCardStyle" 
               TargetType="Border">
            <Setter Property="Background" 
                    Value="{StaticResource CardGradient}"/>
            <Setter Property="CornerRadius"
                    Value="16"/>
            <Setter Property="Margin" 
                    Value="10"/>
            <Setter Property="Padding" 
                    Value="15"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#8A2BE2" 
                                      Opacity="0.1" 
                                      BlurRadius="15" 
                                      ShadowDepth="0"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AvatarStyle" 
               TargetType="Border">
            <Setter Property="Width" 
                    Value="50"/>
            <Setter Property="Height" 
                    Value="50"/>
            <Setter Property="CornerRadius" 
                    Value="25"/>
            <Setter Property="Background" 
                    Value="#2A2438"/>
            <Setter Property="Margin"
                    Value="0,0,15,0"/>
        </Style>

        <Style x:Key="BanButtonStyle" 
               TargetType="Button">
            <Setter Property="Height" 
                    Value="32"/>
            <Setter Property="Padding" 
                    Value="15,0"/>
            <Setter Property="FontSize" 
                    Value="12"/>
            <Setter Property="FontWeight" 
                    Value="SemiBold"/>
            <Setter Property="Cursor" 
                    Value="Hand"/>
            <Setter Property="BorderThickness" 
                    Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" 
                                     Value="True">
                                <Setter Property="Opacity" 
                                        Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ReasonButtonStyle" 
               TargetType="Button">
            <Setter Property="Height" 
                    Value="32"/>
            <Setter Property="Padding" 
                    Value="12,0"/>
            <Setter Property="FontSize"
                    Value="11"/>
            <Setter Property="Cursor" 
                    Value="Hand"/>
            <Setter Property="BorderThickness" 
                    Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" 
                                     Value="True">
                                <Setter Property="Opacity" 
                                        Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SearchTextBox" 
               TargetType="TextBox">
            <Setter Property="Height" 
                    Value="40"/>
            <Setter Property="Width" 
                    Value="300"/>
            <Setter Property="Background" 
                    Value="#1E1B2E"/>
            <Setter Property="Foreground" 
                    Value="#FFFFFF"/>
            <Setter Property="BorderBrush" 
                    Value="#2A2438"/>
            <Setter Property="BorderThickness" 
                    Value="1"/>
            <Setter Property="FontSize"
                    Value="13"/>
            <Setter Property="Padding" 
                    Value="20,0,15,0"/>
            <Setter Property="VerticalContentAlignment" 
                    Value="Center"/>
            <Setter Property="CaretBrush" 
                    Value="#8A2BE2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Grid>
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="20"/>

                            <TextBlock Text="🔍" 
                                       IsHitTestVisible="False" 
                                       VerticalAlignment="Center" 
                                       Margin="15,0,0,0" 
                                       FontSize="14" 
                                       Opacity="0.5"/>

                            <TextBlock x:Name="Placeholder" 
                                       Text="Поиск по ID, никнейму или email..."
                                       IsHitTestVisible="False"
                                       VerticalAlignment="Center" 
                                       Margin="40,0,0,0"
                                       FontSize="13" 
                                       Foreground="#666"
                                       Opacity="0.5"/>

                            <ScrollViewer x:Name="PART_ContentHost" 
                                          Margin="{TemplateBinding Padding}"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="Placeholder" 
                                        Property="Visibility" 
                                        Value="Visible"/>
                            </Trigger>
                            <Trigger Property="Text" 
                                     Value="{x:Null}">
                                <Setter TargetName="Placeholder" 
                                        Property="Visibility" 
                                        Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" 
                                     Value="True">
                                <Setter TargetName="Placeholder" 
                                        Property="Visibility" 
                                        Value="Collapsed"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BanReasonTextBox" 
               TargetType="TextBox">
            <Setter Property="Height" 
                    Value="80"/>
            <Setter Property="Width" 
                    Value="350"/>
            <Setter Property="Background" 
                    Value="#1E1B2E"/>
            <Setter Property="Foreground" 
                    Value="#FFFFFF"/>
            <Setter Property="BorderBrush" 
                    Value="#2A2438"/>
            <Setter Property="BorderThickness" 
                    Value="1"/>
            <Setter Property="FontSize"
                    Value="13"/>
            <Setter Property="Padding" 
                    Value="15,10"/>
            <Setter Property="VerticalContentAlignment" 
                    Value="Top"/>
            <Setter Property="TextWrapping" 
                    Value="Wrap"/>
            <Setter Property="AcceptsReturn" 
                    Value="True"/>
            <Setter Property="CaretBrush" 
                    Value="#8A2BE2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost" 
                                          Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DialogOverlayStyle" 
               TargetType="Border">
            <Setter Property="Background" 
                    Value="#80000000"/>
        </Style>

        <Style x:Key="DialogStyle" 
               TargetType="Border">
            <Setter Property="Background" 
                    Value="{StaticResource CardGradient}"/>
            <Setter Property="CornerRadius" 
                    Value="16"/>
            <Setter Property="Padding"
                    Value="25"/>
            <Setter Property="Width" 
                    Value="400"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#8A2BE2"
                                      Opacity="0.3"
                                      BlurRadius="25" 
                                      ShadowDepth="0"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" 
                   Text="Управление пользователями"
                   FontSize="24" 
                   FontWeight="Bold"
                   Foreground="#FFFFFF"
                   Margin="0,0,0,20"/>

        <Border Grid.Row="1" Margin="0,0,0,20">
            <TextBox x:Name="SearchBox" 
                     Style="{StaticResource SearchTextBox}"
                     TextChanged="SearchBox_TextChanged"/>
        </Border>

        <ScrollViewer Grid.Row="2" 
                      VerticalScrollBarVisibility="Hidden" 
                      HorizontalScrollBarVisibility="Disabled">

            <ItemsControl x:Name="UsersItemsControl">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource UserCardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Border x:Name="AvatarBorder" 
                                        Width="80" 
                                        Height="80" 
                                        HorizontalAlignment="Center" 
                                        Margin="0,10"
                                        Cursor="Hand"
                                        IsHitTestVisible="True"
                                        CornerRadius="40">
                                    <Grid Width="80" 
                                          Height="80">
                                        <Ellipse x:Name="AvatarEllipse" 
                                                 Width="80"
                                                 Height="80">
                                            <Ellipse.Fill>
                                                <ImageBrush ImageSource="{Binding AvatarImage, FallbackValue=/Assets/static.jpg}"/>
                                            </Ellipse.Fill>
                                            <Ellipse.Effect>
                                                <DropShadowEffect Color="#8A2BE2" 
                                                                  BlurRadius="15" 
                                                                  Opacity="0.5"/>
                                            </Ellipse.Effect>
                                        </Ellipse>
                                    </Grid>
                                </Border>

                                <StackPanel Grid.Column="1" 
                                            VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" 
                                                Margin="0,0,0,5">
                                        <TextBlock Text="{Binding Id}" 
                                                   FontSize="16" 
                                                   Foreground="#666" 
                                                   Margin="10,0,10,0"/>

                                        <TextBlock Text="{Binding Nickname}" 
                                                   FontSize="16" 
                                                   FontWeight="SemiBold" 
                                                   Foreground="#FFFFFF"/>

                                        <Border Background="{Binding IsBanned, 
                                                             Converter={StaticResource BanStatusConverter}}"
                                                CornerRadius="10" 
                                                Padding="8,2" 
                                                Margin="10,0,0,0">
                                            <TextBlock Text="{Binding IsBanned, 
                                                              Converter={StaticResource BanTextConverter}}"
                                                       FontSize="16" 
                                                       Foreground="White"/>
                                        </Border>
                                    </StackPanel>

                                    <TextBlock Text="{Binding Email}" 
                                               FontSize="16" 
                                               Foreground="#888" 
                                               Margin="10,0,0,3"/>

                                    <TextBlock Text="{Binding RegistrationDate, 
                                                      StringFormat='dd.MM.yyyy'}" 
                                               FontSize="16" 
                                               Foreground="#666" 
                                               Margin="10,0,0,3"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2" 
                                            Orientation="Horizontal" 
                                            VerticalAlignment="Center">

                                    <Button x:Name="ReasonButton"
                                            Style="{StaticResource ReasonButtonStyle}"
                                            Background="Transparent"
                                            BorderBrush="#FF5252"
                                            Foreground="#FF5252"
                                            Width="150"
                                            Visibility="{Binding HasBanReason, 
                                                         Converter={StaticResource BoolToVisibility}}"
                                            Click="ShowBanReason_Click"
                                            Tag="{Binding}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="⚠️" 
                                                       Margin="0,0,5,0"/>
                                            <TextBlock Text="Причина бана"/>
                                        </StackPanel>
                                    </Button>

                                    <Button x:Name="BanButton"
                                            Style="{StaticResource BanButtonStyle}"
                                            Background="{Binding IsBanned, 
                                                         Converter={StaticResource BanButtonColorConverter}}"
                                            Foreground="White"
                                            Click="ToggleBan_Click"
                                            Tag="{Binding}"
                                            Width="150"
                                            Margin="10,0,0,0">

                                        <TextBlock Text="{Binding IsBanned, 
                                                          Converter={StaticResource BanButtonTextConverter}}"/>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <StackPanel x:Name="LoadingPanel" 
                    Grid.RowSpan="3"
                    HorizontalAlignment="Center" 
                    VerticalAlignment="Center"
                    Visibility="Collapsed">
            <Border Width="50" 
                    Height="50" 
                    CornerRadius="25" 
                    BorderBrush="#8A2BE2"
                    BorderThickness="3">
                <Border.RenderTransform>
                    <RotateTransform CenterX="25" 
                                     CenterY="25"/>
                </Border.RenderTransform>
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <Trigger Property="Visibility" 
                                     Value="Visible">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation From="0" To="360"
                                                             Duration="0:0:1"
                                                             Storyboard.TargetProperty="RenderTransform.Angle"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
            </Border>
            <TextBlock Text="Загрузка пользователей..." 
                       Foreground="#888" 
                       Margin="0,10,0,0"/>
        </StackPanel>

        <Border x:Name="BanReasonDialog" 
                Style="{StaticResource DialogOverlayStyle}"
                Visibility="Collapsed"
                VerticalAlignment="Center"
                HorizontalAlignment="Stretch">
            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center">
                <Border Style="{StaticResource DialogStyle}">
                    <StackPanel>
                        <TextBlock Text="🚫 Причина блокировки" 
                                   FontSize="18" 
                                   FontWeight="Bold" 
                                   Foreground="#FFFFFF" 
                                   Margin="0,0,0,15"/>
                        <TextBlock x:Name="BanReasonText" 
                                   Text="" 
                                   FontSize="13" 
                                   Foreground="#CCC" 
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,20"/>

                        <Button Content="Закрыть" 
                                Style="{StaticResource BanButtonStyle}"
                                Background="#8A2BE2"
                                Width="100"
                                HorizontalAlignment="Right"
                                Click="CloseBanReasonDialog_Click"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <Border x:Name="BanDialog" 
                Style="{StaticResource DialogOverlayStyle}"
                Visibility="Collapsed"
                VerticalAlignment="Center"
                HorizontalAlignment="Stretch">
            <StackPanel VerticalAlignment="Center" 
                        HorizontalAlignment="Center">
                <Border Style="{StaticResource DialogStyle}">
                    <StackPanel>
                        <TextBlock Text="🔨 Блокировка пользователя" 
                                   FontSize="18" 
                                   FontWeight="Bold" 
                                   Foreground="#FFFFFF"
                                   Margin="0,0,0,15"/>

                        <TextBlock Text="Причина блокировки" 
                                   Foreground="#CCC" 
                                   FontSize="12" 
                                   Margin="0,0,0,5"/>

                        <TextBox x:Name="BanReasonInputBox" 
                                 Style="{StaticResource BanReasonTextBox}"
                                 Width="350"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 Height="80"/>

                        <StackPanel Orientation="Horizontal" 
                                    HorizontalAlignment="Right" 
                                    Margin="0,20,0,0">

                            <Button Content="Отмена" 
                                    Style="{StaticResource ReasonButtonStyle}"
                                    Background="Transparent"
                                    BorderBrush="#2A2438"
                                    Foreground="#AAA"
                                    Width="100"
                                    Click="CancelBan_Click"
                                    Margin="0,0,10,0"/>

                            <Button Content="Забанить" 
                                    Style="{StaticResource BanButtonStyle}"
                                    Background="#FF5252"
                                    Width="100"
                                    Click="ConfirmBan_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</Page>