<Application x:Class="desktop.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:desktop.Converters"
             StartupUri="Windows/Auth/Login.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <converters:BanStatusConverter x:Key="BanStatusConverter"/>
            <converters:BanTextConverter x:Key="BanTextConverter"/>
            <converters:BanButtonColorConverter x:Key="BanButtonColorConverter"/>
            <converters:BanButtonTextConverter x:Key="BanButtonTextConverter"/>
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
            <converters:StatusColorConverter x:Key="StatusColorConverter"/>
            <converters:StatusTextConverter x:Key="StatusTextConverter"/>
            <converters:ModerationStatusConverter x:Key="ModerationStatusConverter"/>
            <converters:RejectedVisibilityConverter x:Key="RejectedVisibilityConverter"/>

            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Light.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>