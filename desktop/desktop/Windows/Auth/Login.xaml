<Window x:Class="desktop.Windows.Auth.Login"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:desktop.Windows.Auth"
        mc:Ignorable="d"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Авторизация" 
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Width="480"
        Height="750"
        Background="#0B0A1A"
        WindowStyle="None"
        MouseLeftButtonDown="Window_MouseDown"
        AllowsTransparency="True">

    <Window.Resources>

        <LinearGradientBrush x:Key="PrimaryGradient" 
                             StartPoint="0,0" 
                             EndPoint="1,1">
            <GradientStop Color="#8A2BE2" 
                          Offset="0"/>
            <GradientStop Color="#FF3C82" 
                          Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="BackgroundGradient" 
                             StartPoint="0,0" 
                             EndPoint="1,1">
            <GradientStop Color="#0B0A1A" 
                          Offset="0"/>
            <GradientStop Color="#1A142F" 
                          Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="CardGradient" 
                             StartPoint="0,0" 
                             EndPoint="1,1">
            <GradientStop Color="#1E1B2E" 
                          Offset="0"/>
            <GradientStop Color="#151225" 
                          Offset="1"/>
        </LinearGradientBrush>

        <Style TargetType="TextBox" 
               x:Key="ModernTextBox">
            <Setter Property="Height" 
                    Value="50"/>
            <Setter Property="Background" 
                    Value="#1E1B2E"/>
            <Setter Property="Foreground" 
                    Value="#FFFFFF"/>
            <Setter Property="BorderBrush" 
                    Value="#2A2438"/>
            <Setter Property="BorderThickness" 
                    Value="1"/>
            <Setter Property="FontSize" 
                    Value="14"/>
            <Setter Property="Padding" 
                    Value="15,0,15,0"/>
            <Setter Property="VerticalContentAlignment" 
                    Value="Center"/>
            <Setter Property="CaretBrush" 
                    Value="#8A2BE2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Grid>
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="12"/>
                            <ScrollViewer x:Name="PART_ContentHost" 
                                          Margin="{TemplateBinding Padding}"/>
                            <TextBlock x:Name="HintText"
                                       Text=""
                                       IsHitTestVisible="False"
                                       Opacity="0.4"
                                       VerticalAlignment="Center"
                                       Margin="{TemplateBinding Padding}"
                                       FontSize="14"
                                       Foreground="#FFFFFF"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" 
                                     Value="">
                                <Setter TargetName="HintText" 
                                        Property="Visibility" 
                                        Value="Visible"/>
                            </Trigger>
                            <Trigger Property="Text"
                                     Value="{x:Null}">
                                <Setter TargetName="HintText" 
                                        Property="Visibility" 
                                        Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused"
                                     Value="True">
                                <Setter TargetName="HintText" 
                                        Property="Visibility" 
                                        Value="Collapsed"/>
                            </Trigger>
                            <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource Self}}" 
                                         Value="">
                                <Setter TargetName="HintText" 
                                        Property="Visibility" 
                                        Value="Visible"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="PasswordBox" 
               x:Key="ModernPasswordBox">
            <Setter Property="Height" 
                    Value="50"/>
            <Setter Property="Background" 
                    Value="#1E1B2E"/>
            <Setter Property="Foreground" 
                    Value="#FFFFFF"/>
            <Setter Property="BorderBrush" 
                    Value="#2A2438"/>
            <Setter Property="BorderThickness" 
                    Value="1"/>
            <Setter Property="FontSize" 
                    Value="14"/>
            <Setter Property="Padding"
                    Value="15,0,15,0"/>
            <Setter Property="VerticalContentAlignment" 
                    Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Grid>
                            <Border x:Name="Border"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="12"/>
                            <ScrollViewer x:Name="PART_ContentHost" 
                                          Margin="{TemplateBinding Padding}"/>
                            <TextBlock x:Name="HintText"
                                       Text=""
                                       IsHitTestVisible="False"
                                       Opacity="0.4"
                                       VerticalAlignment="Center"
                                       Margin="{TemplateBinding Padding}"
                                       FontSize="14"
                                       Foreground="#FFFFFF"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" 
                                     Value="True">
                                <Setter TargetName="HintText" 
                                        Property="Visibility" 
                                        Value="Collapsed"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" 
               x:Key="LoginButton">
            <Setter Property="Height" 
                    Value="50"/>
            <Setter Property="Background" 
                    Value="{StaticResource PrimaryGradient}"/>
            <Setter Property="Foreground" 
                    Value="White"/>
            <Setter Property="FontSize" 
                    Value="16"/>
            <Setter Property="FontWeight" 
                    Value="SemiBold"/>
            <Setter Property="Cursor" 
                    Value="Hand"/>
            <Setter Property="BorderThickness" 
                    Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="25">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" 
                                     Value="True">
                                <Setter Property="Opacity" 
                                        Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" 
                                     Value="True">
                                <Setter Property="Opacity" 
                                        Value="0.8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" 
                                     Value="False">
                                <Setter Property="Opacity" 
                                        Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseButtonStyle" 
               TargetType="Button">
            <Setter Property="Width" 
                    Value="35"/>
            <Setter Property="Height" 
                    Value="35"/>
            <Setter Property="HorizontalAlignment" 
                    Value="Right"/>
            <Setter Property="VerticalAlignment" 
                    Value="Top"/>
            <Setter Property="Margin" 
                    Value="0,20,25,0"/>
            <Setter Property="Background"
                    Value="Transparent"/>
            <Setter Property="Foreground" 
                    Value="#888"/>
            <Setter Property="BorderThickness" 
                    Value="0"/>
            <Setter Property="FontSize" 
                    Value="18"/>
            <Setter Property="Cursor" 
                    Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse x:Name="BgCircle" 
                                     Fill="Transparent" 
                                     Width="35" 
                                     Height="35"/>

                            <TextBlock x:Name="CloseText"
                                       Text="✕"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="18"
                                       Foreground="{TemplateBinding Foreground}"
                                       FontFamily="Segoe UI"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" 
                                     Value="True">
                                <Setter TargetName="CloseText" 
                                        Property="Foreground" 
                                        Value="White"/>
                                <Setter TargetName="CloseText" 
                                        Property="FontWeight" 
                                        Value="Bold"/>
                            </Trigger>

                            <Trigger Property="IsPressed" 
                                     Value="True">
                                <Setter TargetName="BgCircle" 
                                        Property="Width" 
                                        Value="32"/>
                                <Setter TargetName="BgCircle" 
                                        Property="Height" 
                                        Value="32"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBlock" 
               x:Key="ErrorText">
            <Setter Property="Foreground" 
                    Value="#FF5252"/>
            <Setter Property="FontSize" 
                    Value="12"/>
            <Setter Property="Margin" 
                    Value="15,5,15,0"/>
            <Setter Property="TextWrapping" 
                    Value="Wrap"/>
        </Style>

        <Style x:Key="SpinnerStyle" 
               TargetType="Border">
            <Setter Property="Width" 
                    Value="30"/>
            <Setter Property="Height" 
                    Value="30"/>
            <Setter Property="CornerRadius" 
                    Value="15"/>
            <Setter Property="BorderBrush" 
                    Value="#8A2BE2"/>
            <Setter Property="BorderThickness" 
                    Value="3"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <RotateTransform CenterX="15" 
                                     CenterY="15"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Visibility" 
                         Value="Visible">
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard RepeatBehavior="Forever">
                                <DoubleAnimation From="0" To="360"
                                                 Duration="0:0:1"
                                                 Storyboard.TargetProperty="RenderTransform.Angle"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" 
                    Value="#AAA"/>
            <Setter Property="FontSize"
                    Value="12"/>
            <Setter Property="Cursor" 
                    Value="Hand"/>
            <Setter Property="VerticalAlignment" 
                    Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid>
                            <StackPanel Orientation="Horizontal" 
                                        VerticalAlignment="Center">
                                <Border x:Name="CheckBoxBorder" 
                                        Width="18" 
                                        Height="18" 
                                        CornerRadius="4" 
                                        Background="#1E1B2E" 
                                        BorderBrush="#2A2438" 
                                        BorderThickness="1"
                                        Margin="0,0,10,0">
                                    <Path x:Name="CheckMark" 
                                          Data="M 0,5 L 4,9 L 9,0" 
                                          Stroke="Transparent" 
                                          StrokeThickness="2" 
                                          StrokeEndLineCap="Round" 
                                          StrokeStartLineCap="Round"
                                          Stretch="None"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Width="12"
                                          Height="10"/>
                                </Border>

                                <ContentPresenter x:Name="ContentPresenter" 
                                                  Content="{TemplateBinding Content}"
                                                  VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CheckBoxBorder" 
                                        Property="BorderBrush" 
                                        Value="#8A2BE2"/>
                                <Setter Property="Foreground" 
                                        Value="#FFFFFF"/>
                            </Trigger>

                            <Trigger Property="IsPressed" 
                                     Value="True">
                                <Setter TargetName="CheckBoxBorder" 
                                        Property="Background" 
                                        Value="#2A2438"/>
                            </Trigger>

                            <Trigger Property="IsChecked" 
                                     Value="True">
                                <Setter TargetName="CheckBoxBorder" 
                                        Property="BorderBrush" 
                                        Value="#8A2BE2"/>
                                <Setter TargetName="CheckMark" 
                                        Property="Stroke" 
                                        Value="#8A2BE2"/>
                            </Trigger>

                            <Trigger Property="IsEnabled"
                                     Value="False">
                                <Setter Property="Foreground"
                                        Value="#555"/>
                                <Setter TargetName="CheckBoxBorder" 
                                        Property="BorderBrush" 
                                        Value="#2A2438"/>
                                <Setter TargetName="CheckMark" 
                                        Property="Stroke" 
                                        Value="#2A2438"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid Background="{StaticResource BackgroundGradient}">
        <Border CornerRadius="20" 
                Background="{StaticResource CardGradient}" 
                Margin="30">

            <Border.Effect>
                <DropShadowEffect Color="#8A2BE2" 
                                  Opacity="0.2" 
                                  BlurRadius="30" 
                                  ShadowDepth="0"/>
            </Border.Effect>

            <StackPanel Margin="40,45,40,45">
                <StackPanel HorizontalAlignment="Center" 
                            Margin="0,0,0,30">
                    <TextBlock FontSize="36" 
                               FontWeight="Bold" 
                               TextAlignment="Center"
                               FontFamily="Segoe UI">
                        <Run Text="FAN" 
                             Foreground="#8A2BE2"/>
                        <Run Text="VERSE" 
                             Foreground="#FF3C82"/>
                    </TextBlock>
                    <TextBlock Text="Между строк рождаются миры"
                               FontSize="14"
                               Foreground="#888"
                               Opacity="0.7"
                               HorizontalAlignment="Center"
                               Margin="0,5,0,0"/>
                    <Line X1="0" 
                          Y1="0" 
                          X2="200" 
                          Y2="0" 
                          Stretch="Fill" 
                          Stroke="#8A2BE2" 
                          StrokeThickness="2" 
                          Margin="0,15,0,0" 
                          Opacity="0.5"/>
                </StackPanel>

                <TextBlock Text="Добро пожаловать"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="#FFFFFF"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,5"/>
                <TextBlock Text="Войдите в панель управления"
                           FontSize="13"
                           Foreground="#999"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,30"/>

                <TextBlock Text="Электронная почта"
                           Foreground="#CCC"
                           FontSize="12"
                           Margin="0,0,0,5"/>
                <TextBox x:Name="EmailBox"
                         Style="{StaticResource ModernTextBox}"
                         FontSize="14"/>

                <TextBlock Text="Пароль"
                           Foreground="#CCC"
                           FontSize="12"
                           Margin="0,20,0,5"/>
                <PasswordBox x:Name="PasswordBox"
                             Style="{StaticResource ModernPasswordBox}"
                             FontSize="14"/>

                <CheckBox x:Name="RememberCheckBox"
                          Content="Запомнить меня"
                          Foreground="#AAA"
                          FontSize="12"
                          Margin="0,15,0,0"/>

                <TextBlock x:Name="ForgotPasswordLink"
                           Text="Забыли пароль?"
                           FontSize="12"
                           Foreground="#8A2BE2"
                           Cursor="Hand"
                           HorizontalAlignment="Right"
                           Margin="0,15,0,0"
                           TextDecorations="Underline">
                    <TextBlock.InputBindings>
                        <MouseBinding MouseAction="LeftClick" 
                                      Command="{Binding ForgotPasswordCommand}"
                                      CommandParameter="{Binding ElementName=ForgotPasswordLink}"/>
                    </TextBlock.InputBindings>
                </TextBlock>

                <Button x:Name="LoginButton"
                        Style="{StaticResource LoginButton}"
                        Content="ВОЙТИ"
                        Margin="0,25,0,0"
                        Click="LoginButton_Click"/>

                <TextBlock x:Name="ErrorTextBlock"
                           Style="{StaticResource ErrorText}"
                           Visibility="Collapsed"/>

                <Border x:Name="LoadingSpinner"
                        Style="{StaticResource SpinnerStyle}"
                        Visibility="Collapsed"
                        Margin="0,15,0,0"/>

                <TextBlock Text="Только для администраторов и модераторов"
                           FontSize="10"
                           Foreground="#555"
                           HorizontalAlignment="Center"
                           Margin="0,25,0,0"/>

            </StackPanel>

        </Border>

        <Button x:Name="CloseButton"
                Style="{StaticResource CloseButtonStyle}"
                Margin="0,40,40,0"
                Click="CloseButton_Click"/>
    </Grid>
</Window>