<Window x:Class="desktop.Windows.Action.ChapterViewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Чтение главы"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        MinWidth="800" MinHeight="600"
        Width="900" Height="700"
        Background="#0B0A1A"
        WindowStyle="None"
        AllowsTransparency="True"
        MouseLeftButtonDown="Window_MouseDown">

    <Window.Resources>
        <LinearGradientBrush x:Key="PrimaryGradient" 
                             StartPoint="0,0" 
                             EndPoint="1,1">
            <GradientStop Color="#8A2BE2" 
                          Offset="0"/>
            <GradientStop Color="#FF3C82"
                          Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="CardGradient"
                             StartPoint="0,0" 
                             EndPoint="1,1">
            <GradientStop Color="#1E1B2E" 
                          Offset="0"/>
            <GradientStop Color="#151225" 
                          Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="CloseButtonStyle" 
               TargetType="Button">
            <Setter Property="Width" 
                    Value="35"/>
            <Setter Property="Height" 
                    Value="35"/>
            <Setter Property="HorizontalAlignment" 
                    Value="Right"/>
            <Setter Property="VerticalAlignment" 
                    Value="Top"/>
            <Setter Property="Margin" 
                    Value="0,15,15,0"/>
            <Setter Property="Background" 
                    Value="Transparent"/>
            <Setter Property="Foreground" 
                    Value="#888"/>
            <Setter Property="BorderThickness" 
                    Value="0"/>
            <Setter Property="FontSize" 
                    Value="18"/>
            <Setter Property="Cursor" 
                    Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse x:Name="BgCircle" 
                                     Fill="Transparent" 
                                     Width="35" 
                                     Height="35"/>
                            <TextBlock x:Name="CloseText" 
                                       Text="✕" 
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" 
                                       FontSize="18" 
                                       Foreground="{TemplateBinding Foreground}"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" 
                                     Value="True">
                                <Setter TargetName="CloseText" 
                                        Property="Foreground" 
                                        Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Border Background="#0B0A1A" 
                CornerRadius="16" 
                Margin="5">
            <Border Background="{StaticResource CardGradient}" 
                    CornerRadius="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Button Grid.Row="0" 
                            Style="{StaticResource CloseButtonStyle}" 
                            Click="CloseButton_Click"/>

                    <ScrollViewer Grid.Row="1" 
                                  Margin="30,50,30,20"
                                  VerticalScrollBarVisibility="Hidden" 
                                  HorizontalScrollBarVisibility="Hidden">
                        <StackPanel>
                            <TextBlock x:Name="ChapterTitleText" 
                                       FontSize="24" 
                                       FontWeight="Bold" 
                                       Foreground="#FFFFFF" 
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,10"/>

                            <TextBlock x:Name="ChapterMetaText" 
                                       FontSize="12" 
                                       Foreground="#888" 
                                       Margin="0,0,0,20"/>

                            <Separator Background="#2A2438" 
                                       Height="1" 
                                       Margin="0,0,0,20"/>

                            <ScrollViewer x:Name="ContentScrollViewer" 
                                          VerticalScrollBarVisibility="Hidden" 
                                          HorizontalScrollBarVisibility="Hidden"
                                          Height="500">
                                <wv2:WebView2 x:Name="ContentWebView"/>
                            </ScrollViewer>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Border>
    </Grid>
</Window>