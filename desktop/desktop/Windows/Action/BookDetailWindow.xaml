<Window x:Class="desktop.Windows.Action.BookDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Детали книги"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Width="1000" 
        Height="800"
        Background="#0B0A1A"
        WindowStyle="None"
        AllowsTransparency="True"
        MouseLeftButtonDown="Window_MouseDown">

    <Window.Resources>
        <LinearGradientBrush x:Key="PrimaryGradient" 
                             StartPoint="0,0" 
                             EndPoint="1,1">
            <GradientStop Color="#8A2BE2"
                          Offset="0"/>
            <GradientStop Color="#FF3C82" 
                          Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="CardGradient"
                             StartPoint="0,0" 
                             EndPoint="1,1">
            <GradientStop Color="#1E1B2E" 
                          Offset="0"/>
            <GradientStop Color="#151225" 
                          Offset="1"/>
        </LinearGradientBrush>

        <Style TargetType="ComboBox" 
               x:Key="ModernComboBox">
            <Setter Property="Height" 
                    Value="35"/>
            <Setter Property="Width" 
                    Value="170"/>
            <Setter Property="Background" 
                    Value="#1E1B2E"/>
            <Setter Property="Foreground" 
                    Value="#FFFFFF"/>
            <Setter Property="BorderBrush" 
                    Value="#2A2438"/>
            <Setter Property="BorderThickness" 
                    Value="1"/>
            <Setter Property="FontSize" 
                    Value="12"/>
            <Setter Property="Margin" 
                    Value="10,0,0,0"/>
            <Setter Property="Cursor" 
                    Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="Border" 
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6"/>

                            <ToggleButton x:Name="ToggleButton"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Grid Background="Transparent">
                                            <Path x:Name="Arrow"
                                                  Data="M0,0 L4,4 L8,0"
                                                  Stroke="#888"
                                                  StrokeThickness="1.5"
                                                  HorizontalAlignment="Right"
                                                  VerticalAlignment="Center"
                                                  Margin="0,0,12,0"/>
                                        </Grid>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" 
                                                     Value="True">
                                                <Setter TargetName="Arrow" 
                                                        Property="Data" 
                                                        Value="M0,4 L4,0 L8,4"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <ContentPresenter x:Name="ContentPresenter"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                              HorizontalAlignment="Left"
                                              VerticalAlignment="Center"
                                              Margin="10,0,30,0"
                                              IsHitTestVisible="False"/>

                            <Popup x:Name="Popup"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Grid>
                                    <Border x:Name="DropDownBorder"
                                            Background="#1E1B2E"
                                            BorderBrush="#2A2438"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Margin="0,2,0,0"
                                            MinWidth="{TemplateBinding ActualWidth}">
                                        <ScrollViewer>
                                            <ItemsPresenter/>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" 
                                     Value="True">
                                <Setter TargetName="Border" 
                                        Property="BorderBrush" 
                                        Value="#8A2BE2"/>
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" 
                                     Value="True">
                                <Setter TargetName="Border" 
                                        Property="BorderBrush" 
                                        Value="#8A2BE2"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" 
                                     Value="False">
                                <Setter Property="Foreground" 
                                        Value="#666"/>
                                <Setter TargetName="Border" 
                                        Property="BorderBrush" 
                                        Value="#2A2438"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" 
                    Value="Transparent"/>
            <Setter Property="Foreground" 
                    Value="#CCC"/>
            <Setter Property="Padding" 
                    Value="10,8"/>
            <Setter Property="Cursor" 
                    Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter Property="Background"
                                        Value="#2A2438"/>
                                <Setter Property="Foreground" 
                                        Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsSelected" 
                                     Value="True">
                                <Setter Property="Background" 
                                        Value="#2A2438"/>
                                <Setter Property="Foreground" 
                                        Value="#8A2BE2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseButtonStyle" 
               TargetType="Button">
            <Setter Property="Width" 
                    Value="35"/>
            <Setter Property="Height" 
                    Value="35"/>
            <Setter Property="HorizontalAlignment" 
                    Value="Right"/>
            <Setter Property="VerticalAlignment" 
                    Value="Top"/>
            <Setter Property="Margin" 
                    Value="0,15,15,0"/>
            <Setter Property="Background" 
                    Value="Transparent"/>
            <Setter Property="Foreground" 
                    Value="#888"/>
            <Setter Property="BorderThickness" 
                    Value="0"/>
            <Setter Property="FontSize" 
                    Value="18"/>
            <Setter Property="Cursor" 
                    Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse x:Name="BgCircle" 
                                     Fill="Transparent" 
                                     Width="35" 
                                     Height="35"/>
                            <TextBlock x:Name="CloseText" 
                                       Text="✕" 
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" 
                                       FontSize="18" 
                                       Foreground="{TemplateBinding Foreground}"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" 
                                     Value="True">
                                <Setter TargetName="CloseText" 
                                        Property="Foreground" 
                                        Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RejectionViewButtonStyle" 
       TargetType="Button">
            <Setter Property="Height" 
            Value="28"/>
            <Setter Property="Width" 
            Value="80"/>
            <Setter Property="Background" 
            Value="Transparent"/>
            <Setter Property="Foreground" 
            Value="#FF5252"/>
            <Setter Property="BorderBrush" 
            Value="#FF5252"/>
            <Setter Property="BorderThickness" 
            Value="1"/>
            <Setter Property="FontSize" 
            Value="11"/>
            <Setter Property="Cursor" 
            Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" 
                                      VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" 
                             Value="True">
                                <Setter Property="Background" 
                                Value="#FF5252"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ChapterItemStyle" 
               TargetType="Border">
            <Setter Property="Background" 
                    Value="{StaticResource CardGradient}"/>
            <Setter Property="CornerRadius" 
                    Value="10"/>
            <Setter Property="Padding" 
                    Value="15"/>
            <Setter Property="Margin" 
                    Value="0,0,0,10"/>
            <Setter Property="Cursor"
                    Value="Hand"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#8A2BE2" 
                                      Opacity="0.1"
                                      BlurRadius="10" 
                                      ShadowDepth="0"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ReadChapterButtonStyle" 
               TargetType="Button">
            <Setter Property="Height" 
                    Value="35"/>
            <Setter Property="Padding" 
                    Value="20,0"/>
            <Setter Property="Background" 
                    Value="{StaticResource PrimaryGradient}"/>
            <Setter Property="Foreground" 
                    Value="White"/>
            <Setter Property="FontSize" 
                    Value="13"/>
            <Setter Property="FontWeight" 
                    Value="SemiBold"/>
            <Setter Property="Cursor" 
                    Value="Hand"/>
            <Setter Property="BorderThickness" 
                    Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" 
                                     Value="True">
                                <Setter Property="Opacity"
                                        Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DialogOverlayStyle" 
               TargetType="Border">
            <Setter Property="Background" 
                    Value="#80000000"/>
        </Style>

        <Style x:Key="DialogStyle" 
               TargetType="Border">
            <Setter Property="Background" 
                    Value="{StaticResource CardGradient}"/>
            <Setter Property="CornerRadius" 
                    Value="16"/>
            <Setter Property="Padding"
                    Value="25"/>
            <Setter Property="Width" 
                    Value="400"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#8A2BE2"
                                      Opacity="0.3"
                                      BlurRadius="25" 
                                      ShadowDepth="0"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RejectReasonStyle" 
               TargetType="TextBox">
            <Setter Property="Height" 
                    Value="80"/>
            <Setter Property="Width" 
                    Value="350"/>
            <Setter Property="Background" 
                    Value="#1E1B2E"/>
            <Setter Property="Foreground" 
                    Value="#FFFFFF"/>
            <Setter Property="BorderBrush" 
                    Value="#2A2438"/>
            <Setter Property="BorderThickness" 
                    Value="1"/>
            <Setter Property="FontSize"
                    Value="13"/>
            <Setter Property="Padding" 
                    Value="15,10"/>
            <Setter Property="VerticalContentAlignment" 
                    Value="Top"/>
            <Setter Property="TextWrapping" 
                    Value="Wrap"/>
            <Setter Property="AcceptsReturn" 
                    Value="True"/>
            <Setter Property="CaretBrush" 
                    Value="#8A2BE2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost" 
                                          Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RejectButtonStyle" 
               TargetType="Button">
            <Setter Property="Height" 
                    Value="32"/>
            <Setter Property="Padding" 
                    Value="15,0"/>
            <Setter Property="FontSize" 
                    Value="12"/>
            <Setter Property="FontWeight" 
                    Value="SemiBold"/>
            <Setter Property="Cursor" 
                    Value="Hand"/>
            <Setter Property="BorderThickness" 
                    Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" 
                                     Value="True">
                                <Setter Property="Opacity" 
                                        Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ReasonButtonStyle" 
               TargetType="Button">
            <Setter Property="Height" 
                    Value="32"/>
            <Setter Property="Padding" 
                    Value="12,0"/>
            <Setter Property="FontSize"
                    Value="11"/>
            <Setter Property="Cursor" 
                    Value="Hand"/>
            <Setter Property="BorderThickness" 
                    Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" 
                                     Value="True">
                                <Setter Property="Opacity" 
                                        Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Border Background="#0B0A1A" 
                CornerRadius="16" 
                Margin="5">
            <Border Background="{StaticResource CardGradient}" 
                    CornerRadius="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Button Grid.Row="0" 
                            Style="{StaticResource CloseButtonStyle}" 
                            Click="CloseButton_Click"/>

                    <ScrollViewer Grid.Row="1" 
                                  VerticalScrollBarVisibility="Hidden" 
                                  HorizontalScrollBarVisibility="Disabled" 
                                  Margin="30,50,30,30">
                        <StackPanel>
                            <Grid Margin="0,0,0,30">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" 
                                        Width="200"
                                        Height="280" 
                                        CornerRadius="12" 
                                        Background="#2A2438"
                                        Margin="0,0,25,0">
                                    <Image x:Name="CoverImage" 
                                           Stretch="UniformToFill"/>
                                </Border>

                                <StackPanel Grid.Column="1" 
                                            VerticalAlignment="Center">
                                    <TextBlock x:Name="TitleText" 
                                               FontSize="28" 
                                               FontWeight="Bold" 
                                               Foreground="#FFFFFF" 
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,10"/>

                                    <TextBlock x:Name="AuthorText" 
                                               FontSize="14" 
                                               Foreground="#8A2BE2" 
                                               Margin="0,0,0,15"/>

                                    <WrapPanel Margin="0,0,0,15">
                                        <Border Background="#2A2438"
                                                CornerRadius="8" 
                                                Padding="10,5" 
                                                Margin="0,0,10,5">
                                            <TextBlock x:Name="ViewsText" 
                                                       FontSize="12" 
                                                       Foreground="#CCC"/>
                                        </Border>
                                        <Border Background="#2A2438"
                                                CornerRadius="8" 
                                                Padding="10,5" 
                                                Margin="0,0,10,5">
                                            <TextBlock x:Name="LikesText"
                                                       FontSize="12"
                                                       Foreground="#CCC"/>
                                        </Border>
                                        <Border Background="#2A2438"
                                                CornerRadius="8" 
                                                Padding="10,5" 
                                                Margin="0,0,10,5">
                                            <TextBlock x:Name="CommentsText" 
                                                       FontSize="12" 
                                                       Foreground="#CCC"/>
                                        </Border>
                                    </WrapPanel>

                                    <TextBlock x:Name="RatingText" 
                                               FontSize="12" 
                                               Foreground="#888" 
                                               Margin="0,0,0,5"/>
                                    <TextBlock x:Name="StatusText"
                                               FontSize="12"
                                               Foreground="#888"
                                               Margin="0,0,0,5"/>
                                    <TextBlock x:Name="LanguageText" 
                                               FontSize="12" 
                                               Foreground="#888" 
                                               Margin="0,0,0,5"/>
                                    <TextBlock x:Name="WordCountText" 
                                               FontSize="12"
                                               Foreground="#888"/>
                                </StackPanel>
                            </Grid>

                            <Border Background="#2A2438" 
                                    CornerRadius="12" 
                                    Padding="20" 
                                    Margin="0,0,0,30">
                                <StackPanel>
                                    <TextBlock Text="📖 Описание" 
                                               FontSize="16" 
                                               FontWeight="Bold" 
                                               Foreground="#8A2BE2" 
                                               Margin="0,0,0,10"/>
                                    <TextBlock x:Name="SummaryText" 
                                               FontSize="13" 
                                               Foreground="#CCC" 
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <StackPanel>
                                <TextBlock Text="📚 Содержание" 
                                           FontSize="18" 
                                           FontWeight="Bold" 
                                           Foreground="#FFFFFF" 
                                           Margin="0,0,0,15"/>
                                <ItemsControl x:Name="ChaptersList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource ChapterItemStyle}" 
                                                    MouseLeftButtonUp="Chapter_Click"
                                                    Tag="{Binding}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="0.08*"/>
                                                        <ColumnDefinition Width="0.35*"/>
                                                        <ColumnDefinition Width="0.15*"/>
                                                        <ColumnDefinition Width="0.15*"/>
                                                        <ColumnDefinition Width="0.30*"/>
                                                        <ColumnDefinition Width="0.25*"/>
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Grid.Column="0" 
                                                               Text="{Binding ChapterNumber}" 
                                                               FontSize="14" FontWeight="Bold"
                                                               Foreground="#8A2BE2"
                                                               Width="50"
                                                               VerticalAlignment="Center"/>

                                                    <StackPanel Grid.Column="1" 
                                                                Margin="10,0">
                                                        <TextBlock Text="{Binding Title}" 
                                                                   FontSize="14" 
                                                                   FontWeight="SemiBold"
                                                                   Foreground="#FFFFFF"/>
                                                        <TextBlock Text="{Binding CreatedAt, 
                                                                          StringFormat='dd.MM.yyyy'}" 
                                                                   FontSize="11" 
                                                                   Foreground="#666"/>
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="2" 
                                                                Orientation="Horizontal" 
                                                                Margin="10,0,15,0" 
                                                                VerticalAlignment="Center">
                                                        <TextBlock Text="👁 " 
                                                                   Foreground="#666" 
                                                                   FontSize="11"/>
                                                        <TextBlock Text="{Binding Views}" 
                                                                   Foreground="#666" 
                                                                   FontSize="11" 
                                                                   Margin="0,0,8,0"/>
                                                        <TextBlock Text="❤️ " 
                                                                   Foreground="#666" 
                                                                   FontSize="11"/>
                                                        <TextBlock Text="{Binding Likes}" 
                                                                   Foreground="#666" 
                                                                   FontSize="11"/>
                                                    </StackPanel>

                                                    <Border Grid.Column="3" 
                                                            Background="{Binding ModerationStatus, 
                                                                         Converter={StaticResource StatusColorConverter}}"
                                                            CornerRadius="8" 
                                                            Padding="8,4"
                                                            VerticalAlignment="Center"
                                                            Margin="0,0,10,0">
                                                        <TextBlock Text="{Binding ModerationStatus, 
                                                                          Converter={StaticResource ModerationStatusConverter}}"
                                                                   FontSize="10" 
                                                                   HorizontalAlignment="Center"
                                                                   Foreground="White"/>
                                                    </Border>

                                                    <ComboBox Grid.Column="4"
                                                              Style="{StaticResource ModernComboBox}"
                                                              Height="30"
                                                              Tag="{Binding}"
                                                              SelectionChanged="ModerateChapter_SelectionChanged">
                                                        <ComboBoxItem Content="Выберите действие" 
                                                                      IsSelected="True" 
                                                                      IsEnabled="False"/>
                                                        <ComboBoxItem Content="✅ Одобрить" 
                                                                      Tag="approve"/>
                                                        <ComboBoxItem Content="❌ Отклонить" 
                                                                      Tag="reject"/>
                                                    </ComboBox>

                                                    <Button Grid.Column="5"
                                                            Content="📋 Отказ"
                                                            Style="{StaticResource RejectionViewButtonStyle}"
                                                            Width="150" 
                                                            Height="30"
                                                            Background="Transparent"
                                                            BorderBrush="#FF5252"
                                                            BorderThickness="1"
                                                            Cursor="Hand"
                                                            Click="ShowChapterRejection_Click"
                                                            Tag="{Binding}"
                                                            Margin="0,0,10,0"
                                                            Visibility="{Binding ModerationStatus, 
                                                                         Converter={StaticResource RejectedVisibilityConverter}}"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Border>

        <Border x:Name="ChapterRejectDialog" 
                Style="{StaticResource DialogOverlayStyle}"
                Visibility="Collapsed"
                VerticalAlignment="Center"
                HorizontalAlignment="Stretch">
            <StackPanel VerticalAlignment="Center" 
                        HorizontalAlignment="Center">
                <Border Style="{StaticResource DialogStyle}">
                    <StackPanel>
                        <TextBlock Text="❌ Причина отклонения" 
                                   FontSize="18" 
                                   FontWeight="Bold" 
                                   Foreground="#FFFFFF" 
                                   Margin="0,0,0,15"/>

                        <TextBlock Text="Тип нарушения" 
                                   Foreground="#CCC" 
                                   FontSize="12" 
                                   Margin="0,0,0,5"/>

                        <ComboBox x:Name="ViolationTypeBox" 
                                  Style="{StaticResource ModernComboBox}"
                                  Height="35"
                                  Width="370"
                                  Background="#1E1B2E"
                                  Foreground="#FFFFFF"
                                  BorderBrush="#2A2438"
                                  BorderThickness="1"
                                  Margin="0,0,0,15">
                            <ComboBoxItem Content="Спам" 
                                          Tag="Spam" 
                                          IsSelected="True"/>
                            <ComboBoxItem Content="Оскорбления / Ненависть" 
                                          Tag="HateSpeech"/>
                            <ComboBoxItem Content="Нарушение авторских прав" 
                                          Tag="Copyright"/>
                            <ComboBoxItem Content="Слишком откровенный контент" 
                                          Tag="Explicit"/>
                            <ComboBoxItem Content="Другое" 
                                          Tag="Other"/>
                        </ComboBox>

                        <TextBlock Text="Укажите причину отклонения книги" 
                                   Foreground="#CCC" 
                                   FontSize="12" 
                                   Margin="0,0,0,10"/>

                        <TextBox x:Name="RejectReasonBox" 
                                 Height="100"
                                 Style="{StaticResource RejectReasonStyle}"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 Background="#1E1B2E"
                                 Foreground="#FFFFFF"
                                 BorderBrush="#2A2438"
                                 BorderThickness="1"
                                 Padding="15,10"
                                 VerticalContentAlignment="Top"
                                 CaretBrush="#8A2BE2"/>

                        <StackPanel Orientation="Horizontal" 
                                    HorizontalAlignment="Right" 
                                    Margin="0,20,0,0">
                            <Button Content="Отмена" 
                                    Style="{StaticResource ReasonButtonStyle}"
                                    Width="100" 
                                    Height="35"
                                    Background="Transparent"
                                    BorderBrush="#2A2438"
                                    BorderThickness="1"
                                    Foreground="#AAA"
                                    Cursor="Hand"
                                    Click="CancelChapterReject_Click"
                                    Margin="0,0,10,0"/>
                            <Button Content="Отклонить" 
                                    Style="{StaticResource RejectButtonStyle}"
                                    Width="100" 
                                    Height="35"
                                    Background="#FF5252"
                                    Foreground="White"
                                    FontWeight="SemiBold"
                                    Cursor="Hand"
                                    Click="ConfirmChapterReject_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</Window>