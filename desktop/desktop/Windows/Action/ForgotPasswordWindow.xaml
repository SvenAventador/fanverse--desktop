<Window x:Class="desktop.Windows.Action.ForgotPasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Восстановление пароля"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Width="480" 
        Height="650"
        Background="#0B0A1A"
        WindowStyle="None"
        AllowsTransparency="True"
        MouseLeftButtonDown="Window_MouseDown">

    <Window.Resources>
        <LinearGradientBrush x:Key="PrimaryGradient"
                             StartPoint="0,0" 
                             EndPoint="1,1">
            <GradientStop Color="#8A2BE2" 
                          Offset="0"/>
            <GradientStop Color="#FF3C82" 
                          Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="BackgroundGradient" 
                             StartPoint="0,0"
                             EndPoint="1,1">
            <GradientStop Color="#0B0A1A" 
                          Offset="0"/>
            <GradientStop Color="#1A142F" 
                          Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="CardGradient" 
                             StartPoint="0,0"
                             EndPoint="1,1">
            <GradientStop Color="#1E1B2E" 
                          Offset="0"/>
            <GradientStop Color="#151225" 
                          Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="BackButtonStyle" 
               TargetType="Button">
            <Setter Property="Background" 
                    Value="Transparent"/>
            <Setter Property="Foreground" 
                    Value="#888"/>
            <Setter Property="FontSize" 
                    Value="12"/>
            <Setter Property="Cursor" 
                    Value="Hand"/>
            <Setter Property="BorderThickness" 
                    Value="0"/>
            <Setter Property="Padding" 
                    Value="5,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" 
                                     Value="True">
                                <Setter Property="Foreground" 
                                        Value="#FFFFFF"/>
                                <Setter Property="Background" 
                                        Value="#2A2438"/>
                            </Trigger>
                            <Trigger Property="IsPressed"
                                     Value="True">
                                <Setter Property="Opacity"
                                        Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox" 
               x:Key="ModernTextBox">
            <Setter Property="Height" 
                    Value="50"/>
            <Setter Property="Background" 
                    Value="#1E1B2E"/>
            <Setter Property="Foreground" 
                    Value="#FFFFFF"/>
            <Setter Property="BorderBrush" 
                    Value="#2A2438"/>
            <Setter Property="BorderThickness" 
                    Value="1"/>
            <Setter Property="FontSize" 
                    Value="14"/>
            <Setter Property="Padding" 
                    Value="15,0,15,0"/>
            <Setter Property="VerticalContentAlignment" 
                    Value="Center"/>
            <Setter Property="CaretBrush" 
                    Value="#8A2BE2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Grid>
                            <Border x:Name="Border" 
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="12"/>
                            <ScrollViewer x:Name="PART_ContentHost" 
                                          Margin="{TemplateBinding Padding}"/>
                            <TextBlock x:Name="HintText"
                                       Text=""
                                       IsHitTestVisible="False"
                                       Opacity="0.4"
                                       VerticalAlignment="Center"
                                       Margin="{TemplateBinding Padding}"
                                       FontSize="14"
                                       Foreground="#FFFFFF"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="HintText"
                                        Property="Visibility" 
                                        Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" 
                                     Value="True">
                                <Setter TargetName="HintText"
                                        Property="Visibility" 
                                        Value="Collapsed"/>
                                <Setter TargetName="Border" 
                                        Property="BorderBrush" 
                                        Value="#8A2BE2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="PasswordBox" 
               x:Key="ModernPasswordBox">
            <Setter Property="Height" 
                    Value="50"/>
            <Setter Property="Background" 
                    Value="#1E1B2E"/>
            <Setter Property="Foreground" 
                    Value="#FFFFFF"/>
            <Setter Property="BorderBrush" 
                    Value="#2A2438"/>
            <Setter Property="BorderThickness" 
                    Value="1"/>
            <Setter Property="FontSize" 
                    Value="14"/>
            <Setter Property="Padding" 
                    Value="15,0,15,0"/>
            <Setter Property="VerticalContentAlignment" 
                    Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Grid>
                            <Border x:Name="Border" 
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="12"/>
                            <ScrollViewer x:Name="PART_ContentHost" 
                                          Margin="{TemplateBinding Padding}"/>
                            <TextBlock x:Name="HintText"
                                       Text=""
                                       IsHitTestVisible="False"
                                       Opacity="0.4"
                                       VerticalAlignment="Center"
                                       Margin="{TemplateBinding Padding}"
                                       FontSize="14"
                                       Foreground="#FFFFFF"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" 
                                     Value="True">
                                <Setter TargetName="HintText" 
                                        Property="Visibility" 
                                        Value="Collapsed"/>
                                <Setter TargetName="Border" 
                                        Property="BorderBrush" Value="#8A2BE2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" 
               x:Key="ActionButton">
            <Setter Property="Height" 
                    Value="50"/>
            <Setter Property="Background" 
                    Value="{StaticResource PrimaryGradient}"/>
            <Setter Property="Foreground" 
                    Value="White"/>
            <Setter Property="FontSize" 
                    Value="14"/>
            <Setter Property="FontWeight" 
                    Value="SemiBold"/>
            <Setter Property="Cursor" 
                    Value="Hand"/>
            <Setter Property="BorderThickness" 
                    Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="25">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" 
                                     Value="True">
                                <Setter Property="Opacity" 
                                        Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" 
                                     Value="True">
                                <Setter Property="Opacity" 
                                        Value="0.8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled"
                                     Value="False">
                                <Setter Property="Opacity" 
                                        Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StepIndicatorStyle" 
               TargetType="Border">
            <Setter Property="Width" 
                    Value="40"/>
            <Setter Property="Height" 
                    Value="40"/>
            <Setter Property="CornerRadius" 
                    Value="20"/>
            <Setter Property="Background" 
                    Value="#2A2438"/>
            <Setter Property="BorderBrush" 
                    Value="#2A2438"/>
            <Setter Property="BorderThickness" 
                    Value="2"/>
            <Setter Property="Margin" 
                    Value="0"/>
        </Style>

        <Style x:Key="CloseButtonStyle" 
               TargetType="Button">
            <Setter Property="Width"
                    Value="35"/>
            <Setter Property="Height" 
                    Value="35"/>
            <Setter Property="HorizontalAlignment" 
                    Value="Right"/>
            <Setter Property="VerticalAlignment" 
                    Value="Top"/>
            <Setter Property="Margin" 
                    Value="0,15,20,0"/>
            <Setter Property="Background" 
                    Value="Transparent"/>
            <Setter Property="Foreground" 
                    Value="#888"/>
            <Setter Property="BorderThickness" 
                    Value="0"/>
            <Setter Property="FontSize" 
                    Value="18"/>
            <Setter Property="Cursor" 
                    Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse x:Name="BgCircle" 
                                     Fill="Transparent" 
                                     Width="35" 
                                     Height="35"/>
                            <TextBlock x:Name="CloseText" 
                                       Text="✕" 
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" 
                                       FontSize="18" 
                                       Foreground="{TemplateBinding Foreground}"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" 
                                     Value="True">
                                <Setter TargetName="CloseText" 
                                        Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SpinnerStyle" 
               TargetType="Border">
            <Setter Property="Width" 
                    Value="30"/>
            <Setter Property="Height" 
                    Value="30"/>
            <Setter Property="CornerRadius" 
                    Value="15"/>
            <Setter Property="BorderBrush" 
                    Value="#8A2BE2"/>
            <Setter Property="BorderThickness" 
                    Value="3"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <RotateTransform CenterX="15"
                                     CenterY="15"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Visibility" 
                         Value="Visible">
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard RepeatBehavior="Forever">
                                <DoubleAnimation From="0" 
                                                 To="360"
                                                 Duration="0:0:1" 
                                                 Storyboard.TargetProperty="RenderTransform.Angle"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ErrorTextStyle" 
               TargetType="TextBlock">
            <Setter Property="Foreground" 
                    Value="#FF5252"/>
            <Setter Property="FontSize" 
                    Value="11"/>
            <Setter Property="Margin" 
                    Value="15,5,15,0"/>
            <Setter Property="TextWrapping" 
                    Value="Wrap"/>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource BackgroundGradient}">
        <Border CornerRadius="20" 
                Background="{StaticResource CardGradient}" 
                Margin="30">
            <Border.Effect>
                <DropShadowEffect Color="#8A2BE2" 
                                  Opacity="0.2" 
                                  BlurRadius="30" 
                                  ShadowDepth="0"/>
            </Border.Effect>

            <StackPanel Margin="40,45,40,45">
                <StackPanel HorizontalAlignment="Center" 
                            Margin="0,0,0,25">
                    <TextBlock FontSize="36" 
                               FontWeight="Bold" 
                               TextAlignment="Center" 
                               FontFamily="Segoe UI">
                        <Run Text="FAN" 
                             Foreground="#8A2BE2"/>
                        <Run Text="VERSE" 
                             Foreground="#FF3C82"/>
                    </TextBlock>
                    <TextBlock Text="Восстановление пароля" 
                               FontSize="14" 
                               Foreground="#888" 
                               HorizontalAlignment="Center"
                               Margin="0,5,0,0"/>
                </StackPanel>

                <Grid Margin="0,0,0,30">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" 
                            Style="{StaticResource StepIndicatorStyle}" 
                            x:Name="Step1Indicator">
                        <TextBlock x:Name="Step1Text" 
                                   Text="1" 
                                   FontSize="16" 
                                   FontWeight="Bold" 
                                   Foreground="#888" 
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <Line Grid.Column="1" 
                          X1="0" 
                          Y1="0" 
                          X2="40" 
                          Y2="0" 
                          Stroke="#2A2438" 
                          StrokeThickness="2" 
                          VerticalAlignment="Center"
                          Width="40" 
                          Margin="5,0"/>

                    <Border Grid.Column="2" 
                            Style="{StaticResource StepIndicatorStyle}" 
                            x:Name="Step2Indicator">
                        <TextBlock x:Name="Step2Text" 
                                   Text="2" 
                                   FontSize="16" 
                                   FontWeight="Bold" 
                                   Foreground="#888"
                                   HorizontalAlignment="Center" 
                                   VerticalAlignment="Center"/>
                    </Border>

                    <Line Grid.Column="3" 
                          X1="0" 
                          Y1="0" 
                          X2="40" 
                          Y2="0" 
                          Stroke="#2A2438" 
                          StrokeThickness="2" 
                          VerticalAlignment="Center"
                          Width="40" 
                          Margin="5,0"/>

                    <Border Grid.Column="4" 
                            Style="{StaticResource StepIndicatorStyle}" 
                            x:Name="Step3Indicator">
                        <TextBlock x:Name="Step3Text" 
                                   Text="3" 
                                   FontSize="16" 
                                   FontWeight="Bold" 
                                   Foreground="#888"
                                   
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Grid>

                <StackPanel x:Name="Step1Panel">
                    <TextBlock Text="Введите ваш email"
                               FontSize="14" 
                               Foreground="#CCC" 
                               HorizontalAlignment="Center" 
                               Margin="0,0,0,5"/>
                    <TextBlock Text="Мы отправим код для сброса пароля"
                               FontSize="12" 
                               Foreground="#666" 
                               HorizontalAlignment="Center" 
                               Margin="0,0,0,20"/>

                    <TextBlock Text="Email" 
                               Foreground="#CCC"
                               FontSize="12" 
                               Margin="0,0,0,5"/>
                    <TextBox x:Name="EmailBox" 
                             Style="{StaticResource ModernTextBox}" 
                             FontSize="14"/>
                    <TextBlock x:Name="EmailError" 
                               Style="{StaticResource ErrorTextStyle}" 
                               Visibility="Collapsed"/>

                    <Button x:Name="SendCodeButton" 
                            Style="{StaticResource ActionButton}" 
                            Content="Отправить код" 
                            Margin="0,25,0,0" 
                            Click="SendCodeButton_Click"/>
                </StackPanel>

                <StackPanel x:Name="Step2Panel" 
                            Visibility="Collapsed">
                    <TextBlock Text="Введите код подтверждения"
                               FontSize="14" 
                               Foreground="#CCC" 
                               HorizontalAlignment="Center" 
                               Margin="0,0,0,5"/>
                    <TextBlock Text="Код отправлен на вашу почту"
                               FontSize="12" 
                               Foreground="#666"
                               HorizontalAlignment="Center" 
                               Margin="0,0,0,20"/>

                    <TextBlock Text="Код подтверждения" 
                               Foreground="#CCC" 
                               FontSize="12" 
                               Margin="0,0,0,5"/>
                    <TextBox x:Name="CodeBox" 
                             Style="{StaticResource ModernTextBox}" 
                             FontSize="14"/>
                    <TextBlock x:Name="CodeError" 
                               Style="{StaticResource ErrorTextStyle}" 
                               Visibility="Collapsed"/>

                    <Button x:Name="VerifyCodeButton" 
                            Style="{StaticResource ActionButton}" 
                            Content="Подтвердить" 
                            Margin="0,25,0,0" 
                            Click="VerifyCodeButton_Click"/>

                    <Button x:Name="BackToEmailButton" 
                            Content="← Назад" 
                            Background="Transparent"
                            Style="{StaticResource BackButtonStyle}"
                            Foreground="#888"
                            FontSize="12"
                            Cursor="Hand"
                            BorderThickness="0"
                            Margin="0,15,0,0"
                            Click="BackToEmailButton_Click"/>
                </StackPanel>

                <StackPanel x:Name="Step3Panel" 
                            Visibility="Collapsed">
                    <TextBlock Text="Создайте новый пароль"
                               FontSize="14" 
                               Foreground="#CCC" 
                               HorizontalAlignment="Center" 
                               Margin="0,0,0,5"/>
                    <TextBlock Text="Пароль должен быть надёжным"
                               FontSize="12" 
                               Foreground="#666" 
                               HorizontalAlignment="Center" 
                               Margin="0,0,0,20"/>

                    <TextBlock Text="Новый пароль" 
                               Foreground="#CCC" 
                               FontSize="12" 
                               Margin="0,0,0,5"/>
                    <PasswordBox x:Name="NewPasswordBox" 
                                 Style="{StaticResource ModernPasswordBox}" 
                                 FontSize="14"/>
                    <TextBlock x:Name="PasswordError" 
                               Style="{StaticResource ErrorTextStyle}" 
                               Visibility="Collapsed"/>

                    <TextBlock Text="Подтверждение пароля" 
                               Foreground="#CCC" 
                               FontSize="12" 
                               Margin="0,15,0,5"/>
                    <PasswordBox x:Name="ConfirmPasswordBox" 
                                 Style="{StaticResource ModernPasswordBox}" 
                                 FontSize="14"/>
                    <TextBlock x:Name="ConfirmError" 
                               Style="{StaticResource ErrorTextStyle}" 
                               Visibility="Collapsed"/>

                    <Button x:Name="ResetPasswordButton" 
                            Style="{StaticResource ActionButton}" 
                            Content="Сбросить пароль" 
                            Margin="0,25,0,0" 
                            Click="ResetPasswordButton_Click"/>

                    <Button x:Name="BackToCodeButton" 
                            Content="← Назад" 
                            Background="Transparent"
                            Foreground="#888"
                            FontSize="12"
                            Style="{StaticResource BackButtonStyle}"
                            Cursor="Hand"
                            BorderThickness="0"
                            Margin="0,15,0,0"
                            Click="BackToCodeButton_Click"/>
                </StackPanel>

                <Border x:Name="LoadingSpinner" 
                        Style="{StaticResource SpinnerStyle}" 
                        Visibility="Collapsed" 
                        Margin="0,20,0,0" 
                        HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <Button x:Name="CloseButton" 
                Style="{StaticResource CloseButtonStyle}" 
                Click="CloseButton_Click"/>
    </Grid>
</Window>