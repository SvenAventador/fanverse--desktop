<Window x:Class="library.Utils.ChapterRejectionReasonWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Причина отклонения главы"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Width="500" Height="400"
        Background="#0B0A1A"
        WindowStyle="None"
        AllowsTransparency="True"
        MouseLeftButtonDown="Window_MouseDown">

    <Window.Resources>
        <LinearGradientBrush x:Key="CardGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#1E1B2E" Offset="0"/>
            <GradientStop Color="#151225" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="PrimaryGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#8A2BE2" Offset="0"/>
            <GradientStop Color="#FF3C82" Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="CloseButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="35"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
            <Setter Property="Margin" Value="0,15,15,0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#888"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse x:Name="BgCircle" Fill="Transparent" Width="35" Height="35"/>
                            <TextBlock x:Name="CloseText" Text="✕" HorizontalAlignment="Center"
                                       VerticalAlignment="Center" FontSize="18" Foreground="{TemplateBinding Foreground}"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CloseText" Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="35"/>
            <Setter Property="Width" Value="100"/>
            <Setter Property="Background" Value="{StaticResource PrimaryGradient}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Border Background="#0B0A1A" CornerRadius="12" Margin="5">
            <Border Background="{StaticResource CardGradient}" CornerRadius="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Button Grid.Row="0" Style="{StaticResource CloseButtonStyle}" Click="CloseButton_Click"/>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="25,20,25,10">
                        <StackPanel>
                            <TextBlock x:Name="ViolationTypeText" 
                                       FontSize="14" FontWeight="SemiBold"
                                       Foreground="#FF5252"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,15"/>

                            <Separator Background="#2A2438" Height="1" Margin="0,0,0,15"/>

                            <TextBlock Text="Причина:" FontSize="12" Foreground="#8A2BE2" Margin="0,0,0,5"/>
                            <TextBlock x:Name="ReasonText" FontSize="13" Foreground="#CCC" TextWrapping="Wrap" Margin="0,0,0,15"/>

                            <Separator Background="#2A2438" Height="1" Margin="0,0,0,15"/>

                            <TextBlock Text="Дата:" FontSize="12" Foreground="#8A2BE2" Margin="0,0,0,5"/>
                            <TextBlock x:Name="DateText" FontSize="12" Foreground="#888" TextWrapping="Wrap"/>
                        </StackPanel>
                    </ScrollViewer>

                    <Button Grid.Row="2" 
                            Content="Закрыть"
                            Style="{StaticResource ModernButtonStyle}"
                            Click="CloseButton_Click"
                            Margin="0,0,0,20"/>
                </Grid>
            </Border>
        </Border>
    </Grid>
</Window>
