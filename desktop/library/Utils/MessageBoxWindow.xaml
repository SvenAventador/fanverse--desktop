<Window x:Class="library.Utils.MessageBoxWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FanVerse"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Width="450" 
        Height="280"
        Background="#0B0A1A"
        WindowStyle="None"
        AllowsTransparency="True">

    <Window.Resources>
        <LinearGradientBrush x:Key="PrimaryGradient" 
                             StartPoint="0,0"
                             EndPoint="1,1">
            <GradientStop Color="#8A2BE2" 
                          Offset="0"/>
            <GradientStop Color="#FF3C82" 
                          Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="CardGradient" 
                             StartPoint="0,0" 
                             EndPoint="1,1">
            <GradientStop Color="#1E1B2E" 
                          Offset="0"/>
            <GradientStop Color="#151225" 
                          Offset="1"/>
        </LinearGradientBrush>

        <Path x:Key="SuccessIcon" 
              Data="M 9,16.17 L 4.83,12 L 3.41,13.41 L 9,19 L 21,7 L 19.59,5.59 L 9,16.17 Z"
              Fill="#4CAF50" 
              Stretch="Uniform" 
              Width="40" 
              Height="40"/>

        <Path x:Key="QuestionIcon" 
              Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 17h-2v-2h2v2zm2-7h-2v-1c0-1.1-.9-2-2-2H9v2h2v1c0 1.1.9 2 2 2h2v-2z"
              Fill="#FFC107" 
              Stretch="Uniform" 
              Width="40"
              Height="40"/>

        <Path x:Key="ErrorIcon" 
              Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"
              Fill="#FF5252" 
              Stretch="Uniform" 
              Width="40" 
              Height="40"/>

        <Path x:Key="InfoIcon" 
              Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"
              Fill="#8A2BE2" 
              Stretch="Uniform" 
              Width="40" 
              Height="40"/>

        <Style x:Key="OkButtonStyle" 
               TargetType="Button">
            <Setter Property="Height" 
                    Value="40"/>
            <Setter Property="Width"
                    Value="120"/>
            <Setter Property="Background"
                    Value="{StaticResource PrimaryGradient}"/>
            <Setter Property="Foreground"
                    Value="White"/>
            <Setter Property="FontSize" 
                    Value="14"/>
            <Setter Property="FontWeight" 
                    Value="SemiBold"/>
            <Setter Property="Cursor" 
                    Value="Hand"/>
            <Setter Property="BorderThickness" 
                    Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="20">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter Property="Opacity" 
                                        Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="YesButtonStyle" 
               TargetType="Button">
            <Setter Property="Height" 
                    Value="40"/>
            <Setter Property="Width"
                    Value="100"/>
            <Setter Property="Background"
                    Value="{StaticResource PrimaryGradient}"/>
            <Setter Property="Foreground" 
                    Value="White"/>
            <Setter Property="FontSize" 
                    Value="14"/>
            <Setter Property="FontWeight" 
                    Value="SemiBold"/>
            <Setter Property="Cursor" 
                    Value="Hand"/>
            <Setter Property="BorderThickness" 
                    Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="20">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter Property="Opacity" 
                                        Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CancelButtonStyle" 
               TargetType="Button">
            <Setter Property="Height" 
                    Value="40"/>
            <Setter Property="Width" 
                    Value="100"/>
            <Setter Property="Background" 
                    Value="Transparent"/>
            <Setter Property="Foreground" 
                    Value="#AAA"/>
            <Setter Property="FontSize" 
                    Value="14"/>
            <Setter Property="Cursor" 
                    Value="Hand"/>
            <Setter Property="BorderBrush" 
                    Value="#2A2438"/>
            <Setter Property="BorderThickness" 
                    Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="20">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" 
                                     Value="True">
                                <Setter Property="Background" 
                                        Value="#2A2438"/>
                                <Setter Property="Foreground" 
                                        Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseButtonStyle" 
               TargetType="Button">
            <Setter Property="Width" 
                    Value="30"/>
            <Setter Property="Height" 
                    Value="30"/>
            <Setter Property="HorizontalAlignment" 
                    Value="Right"/>
            <Setter Property="VerticalAlignment" 
                    Value="Top"/>
            <Setter Property="Margin"
                    Value="0,10,15,0"/>
            <Setter Property="Background"
                    Value="Transparent"/>
            <Setter Property="Foreground" 
                    Value="#888"/>
            <Setter Property="BorderThickness" 
                    Value="0"/>
            <Setter Property="FontSize" 
                    Value="16"/>
            <Setter Property="Cursor" 
                    Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse x:Name="BgCircle"
                                     Fill="Transparent" 
                                     Width="30"
                                     Height="30"/>
                            <TextBlock x:Name="CloseText" 
                                       Text="✕"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" 
                                       FontSize="16" 
                                       Foreground="{TemplateBinding Foreground}"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" 
                                     Value="True">
                                <Setter TargetName="CloseText"
                                        Property="Foreground" 
                                        Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Border Background="#0B0A1A" 
                CornerRadius="12" 
                Margin="5">
            <Border Background="{StaticResource CardGradient}" 
                    CornerRadius="10">
                <Border.Effect>
                    <DropShadowEffect Color="#8A2BE2" 
                                      Opacity="0.2" 
                                      BlurRadius="20" 
                                      ShadowDepth="0"/>
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Button Grid.Row="0" 
                            Style="{StaticResource CloseButtonStyle}" 
                            Click="CloseButton_Click"/>

                    <StackPanel Grid.Row="1" 
                                Margin="30,20,30,20">
                        <ContentControl x:Name="IconContent" 
                                        HorizontalAlignment="Center"
                                        Margin="0,0,0,15"/>

                        <TextBlock x:Name="TitleText" 
                                   Text="Заголовок"
                                   FontSize="18" 
                                   FontWeight="SemiBold"
                                   Foreground="#FFFFFF"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,10"/>

                        <TextBlock x:Name="MessageText" 
                                   Text="Сообщение"
                                   FontSize="13"
                                   Foreground="#CCC"
                                   HorizontalAlignment="Center"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"/>
                    </StackPanel>

                    <StackPanel x:Name="ButtonsPanel" 
                                Grid.Row="2" 
                                Orientation="Horizontal" 
                                HorizontalAlignment="Center"
                                Margin="0,0,0,25">

                    </StackPanel>
                </Grid>
            </Border>
        </Border>
    </Grid>
</Window>